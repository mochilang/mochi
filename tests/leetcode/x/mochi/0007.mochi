fun reverseDigits(s) {
  var out = ""
  var i = len(s) - 1
  while i >= 0 {
    out = out + s[i:i+1]
    i = i - 1
  }
  return out
}

fun reverseInt(x) {
  let s = str(x)
  let neg = s[:1] == "-"
  let digits = if neg { s[1:] } else { s }
  let rev = int(reverseDigits(digits))
  if neg {
    if rev > 2147483648 {
      return 0
    }
    return 0 - rev
  }
  if rev > 2147483647 {
    return 0
  }
  return rev
}

let t = int(input())
var i = 0
while i < t {
  print(reverseInt(int(input())))
  i = i + 1
}
