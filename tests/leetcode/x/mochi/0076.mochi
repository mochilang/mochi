fun idxChar(ch) {
  let upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
  var i = 0
  while i < 26 {
    if substring(upper, i, i + 1) == ch { return i }
    i = i + 1
  }
  let lower = "abcdefghijklmnopqrstuvwxyz"
  i = 0
  while i < 26 {
    if substring(lower, i, i + 1) == ch { return 26 + i }
    i = i + 1
  }
  return 0
}

fun makeCounts() {
  var arr = []
  var i = 0
  while i < 52 { arr = append(arr, 0); i = i + 1 }
  return arr
}

fun covers(cur, need) {
  var i = 0
  while i < 52 {
    if cur[i] < need[i] { return false }
    i = i + 1
  }
  return true
}

fun minWindow(s, t) {
  let need0 = makeCounts()
  var need = need0
  var i = 0
  while i < len(t) {
    let c = idxChar(substring(t, i, i + 1))
    need[c] = need[c] + 1
    i = i + 1
  }
  var bestStart = 0
  var bestLen = len(s) + 1
  var left = 0
  while left < len(s) {
    let cur0 = makeCounts()
    var cur = cur0
    var right = left
    while right < len(s) {
      let c = idxChar(substring(s, right, right + 1))
      cur[c] = cur[c] + 1
      if covers(cur, need) {
        if right - left + 1 < bestLen {
          bestStart = left
          bestLen = right - left + 1
        }
        right = len(s)
      } else {
        right = right + 1
      }
    }
    left = left + 1
  }
  if bestLen > len(s) { return "" }
  return substring(s, bestStart, bestStart + bestLen)
}

fun readLineNonNil() { let line = input(); return line }
let t = int(readLineNonNil())
var i = 0
while i < t {
  print(minWindow(readLineNonNil(), readLineNonNil()))
  i = i + 1
}
