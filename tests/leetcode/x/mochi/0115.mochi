fun numDistinct(s, t) {
  var dp = []
  var j = 0
  while j <= len(t) {
    dp = append(dp, 0)
    j = j + 1
  }
  dp[0] = 1
  var i = 0
  while i < len(s) {
    j = len(t)
    while j >= 1 {
      if substring(s, i, i + 1) == substring(t, j - 1, j) {
        dp[j] = dp[j] + dp[j - 1]
      }
      j = j - 1
    }
    i = i + 1
  }
  return dp[len(t)]
}

let tc = int(input())
var i = 0
while i < tc {
  print(numDistinct(input(), input()))
  i = i + 1
}
