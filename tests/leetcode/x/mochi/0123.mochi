fun maxProfit(prices) {
  var buy1 = -1000000000
  var sell1 = 0
  var buy2 = -1000000000
  var sell2 = 0
  var i = 0
  while i < len(prices) {
    let p = prices[i]
    if -p > buy1 { buy1 = -p }
    if buy1 + p > sell1 { sell1 = buy1 + p }
    if sell1 - p > buy2 { buy2 = sell1 - p }
    if buy2 + p > sell2 { sell2 = buy2 + p }
    i = i + 1
  }
  return sell2
}

fun readList(n) {
  var prices = []
  var i = 0
  while i < n {
    prices = append(prices, int(input()))
    i = i + 1
  }
  return prices
}

let t = int(input())
var tc = 0
while tc < t {
  let n = int(input())
  print(maxProfit(readList(n)))
  tc = tc + 1
}
