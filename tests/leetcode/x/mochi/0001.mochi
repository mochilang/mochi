fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 {
        parts = append(parts, cur)
        cur = ""
      }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun twoSum(nums: list<int>, target: int): list<int> {
  var i = 0
  while i < len(nums) {
    var j = i + 1
    while j < len(nums) {
      if nums[i] + nums[j] == target {
        return [i, j]
      }
      j = j + 1
    }
    i = i + 1
  }
  return [0, 0]
}

fun main() {
  var tLine = input()
  while tLine == "" { tLine = input() }
  let t = int(tLine)
  var tc = 0
  while tc < t {
    var header = input()
    while header == "" { header = input() }
    let hp = split(header)
    let n = int(hp[0])
    let target = int(hp[1])
    var numsLine = input()
    while numsLine == "" { numsLine = input() }
    let np = split(numsLine)
    var nums: list<int> = []
    var i = 0
    while i < n {
      nums = append(nums, int(np[i]))
      i = i + 1
    }
    let ans = twoSum(nums, target)
    print(str(ans[0]) + " " + str(ans[1]))
    tc = tc + 1
  }
}

main()
