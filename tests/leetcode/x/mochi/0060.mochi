fun getPermutation(n, kInput) {
  var digits = []
  let allDigits = "123456789"
  var i = 1
  while i <= n {
    digits = append(digits, substring(allDigits, i - 1, i))
    i = i + 1
  }
  var facts = []
  facts = append(facts, 1)
  i = 1
  while i <= n {
    facts = append(facts, facts[i - 1] * i)
    i = i + 1
  }
  var k = kInput - 1
  var out = ""
  var rem = n
  while rem >= 1 {
    let block = facts[rem - 1]
    let idx = int(k / block)
    k = k % block
    out = out + digits[idx]
    var next = []
    i = 0
    while i < len(digits) {
      if i != idx { next = append(next, digits[i]) }
      i = i + 1
    }
    digits = next
    rem = rem - 1
  }
  return out
}

fun readLineNonNil() {
  let line = input()
  return line
}

let t = int(readLineNonNil())
var tc = 0
while tc < t {
  let n = int(readLineNonNil())
  let k = int(readLineNonNil())
  print(getPermutation(n, k))
  tc = tc + 1
}
