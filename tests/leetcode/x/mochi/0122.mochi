fun maxProfit(prices) {
  var best = 0
  var i = 1
  while i < len(prices) {
    if prices[i] > prices[i - 1] {
      best = best + (prices[i] - prices[i - 1])
    }
    i = i + 1
  }
  return best
}

fun readList(n) {
  var prices = []
  var i = 0
  while i < n {
    prices = append(prices, int(input()))
    i = i + 1
  }
  return prices
}

let t = int(input())
var tc = 0
while tc < t {
  let n = int(input())
  print(maxProfit(readList(n)))
  tc = tc + 1
}
