fun isDigit(ch) {
  return ch >= "0" && ch <= "9"
}

fun myAtoi(s) {
  var i = 0
  while i < len(s) {
    if s[i:i+1] == " " {
      i = i + 1
    } else {
      break
    }
  }
  var sign = 1
  if i < len(s) {
    if s[i:i+1] == "-" {
      sign = -1
      i = i + 1
    } else {
      if s[i:i+1] == "+" {
        i = i + 1
      }
    }
  }
  var ans = 0
  let limit = if sign > 0 { 7 } else { 8 }
  while i < len(s) {
    let ch = s[i:i+1]
    if isDigit(ch) == false {
      break
    }
    let digit = int(ch)
    if ans > 214748364 {
      return if sign > 0 { 2147483647 } else { 0 - 2147483648 }
    }
    if ans == 214748364 {
      if digit > limit {
        return if sign > 0 { 2147483647 } else { 0 - 2147483648 }
      }
    }
    ans = ans * 10 + digit
    i = i + 1
  }
  return sign * ans
}

let t = int(input())
var i = 0
while i < t {
  print(myAtoi(input()))
  i = i + 1
}
