fun sortVals(vals) {
  var i = 0
  while i < len(vals) {
    var j = i + 1
    while j < len(vals) {
      if vals[j] < vals[i] {
        let tmp = vals[i]
        vals[i] = vals[j]
        vals[j] = tmp
      }
      j = j + 1
    }
    i = i + 1
  }
  return vals
}
fun listString(vals) {
  var s = "["
  var i = 0
  while i < len(vals) {
    if i > 0 { s = s + "," }
    s = s + str(vals[i])
    i = i + 1
  }
  return s + "]"
}
fun readIntLine() {
  var line = input()
  while line == "" { line = input() }
  return int(line)
}
let t = readIntLine()
var tc = 0
while tc < t {
  let k = readIntLine()
  var vals = []
  var i = 0
  while i < k {
    let n = readIntLine()
    var j = 0
    while j < n {
      vals = append(vals, readIntLine())
      j = j + 1
    }
    i = i + 1
  }
  print(listString(sortVals(vals)))
  tc = tc + 1
}
