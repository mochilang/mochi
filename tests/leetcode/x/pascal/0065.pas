program Main; uses SysUtils; function IsNumber(s: AnsiString): Boolean; var i: LongInt; seenDigit, seenDot, seenExp, digitAfterExp: Boolean; ch: Char; begin seenDigit:=False; seenDot:=False; seenExp:=False; digitAfterExp:=True; for i:=1 to Length(s) do begin ch:=s[i]; if (ch>='0') and (ch<='9') then begin seenDigit:=True; if seenExp then digitAfterExp:=True; end else if (ch='+') or (ch='-') then begin if (i<>1) and (s[i-1]<>'e') and (s[i-1]<>'E') then begin IsNumber:=False; Exit; end; end else if ch='.' then begin if seenDot or seenExp then begin IsNumber:=False; Exit; end; seenDot:=True; end else if (ch='e') or (ch='E') then begin if seenExp or (not seenDigit) then begin IsNumber:=False; Exit; end; seenExp:=True; digitAfterExp:=False; end else begin IsNumber:=False; Exit; end; end; IsNumber:=seenDigit and digitAfterExp; end; var t,i:LongInt; s:AnsiString; begin if EOF then Halt(0); ReadLn(t); for i:=1 to t do begin ReadLn(s); if IsNumber(s) then Write('true') else Write('false'); if i<t then WriteLn; end; end.
