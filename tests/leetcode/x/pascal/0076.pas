program Main; uses SysUtils; function MinWindow(s,t:AnsiString):AnsiString; var need: array[0..127] of LongInt; missing,left,bestStart,bestLen,right,c,lc,i: LongInt; begin FillChar(need, SizeOf(need), 0); missing:=Length(t); for i:=1 to Length(t) do need[Ord(t[i])] := need[Ord(t[i])] + 1; left:=1; bestStart:=1; bestLen:=Length(s)+1; for right:=1 to Length(s) do begin c:=Ord(s[right]); if need[c] > 0 then missing:=missing-1; need[c]:=need[c]-1; while missing=0 do begin if right-left+1<bestLen then begin bestStart:=left; bestLen:=right-left+1; end; lc:=Ord(s[left]); need[lc]:=need[lc]+1; if need[lc] > 0 then missing:=missing+1; left:=left+1; end; end; if bestLen>Length(s) then MinWindow:='' else MinWindow:=Copy(s,bestStart,bestLen); end; var tcase,i:LongInt; s,p:AnsiString; begin if EOF then Halt(0); ReadLn(tcase); for i:=1 to tcase do begin ReadLn(s); ReadLn(p); Write(MinWindow(s,p)); if i<tcase then WriteLn; end; end.
