program Main; uses SysUtils; type TStringArray = array of AnsiString;
function Spaces(n: LongInt): AnsiString; begin Spaces := StringOfChar(' ', n); end;
function Justify(words: TStringArray; maxWidth: LongInt): TStringArray; var res: TStringArray; i,j,total,gaps,spacesCnt,base,extra,k,cnt: LongInt; line: AnsiString; begin SetLength(res,0); i:=0; while i<Length(words) do begin j:=i; total:=0; while (j<Length(words)) and (total+Length(words[j])+(j-i)<=maxWidth) do begin total:=total+Length(words[j]); j:=j+1; end; gaps:=j-i-1; if (j=Length(words)) or (gaps=0) then begin line:=''; for k:=i to j-1 do begin if k>i then line:=line+' '; line:=line+words[k]; end; line:=line+Spaces(maxWidth-Length(line)); end else begin spacesCnt:=maxWidth-total; base:=spacesCnt div gaps; extra:=spacesCnt mod gaps; line:=''; for k:=i to j-2 do begin line:=line+words[k]+Spaces(base + Ord(k-i<extra)); end; line:=line+words[j-1]; end; cnt:=Length(res); SetLength(res,cnt+1); res[cnt]:=line; i:=j; end; Justify:=res; end;
var t,tc,n,i,width: LongInt; words,ans: TStringArray; s: AnsiString; begin if EOF then Halt(0); ReadLn(t); for tc:=1 to t do begin ReadLn(n); SetLength(words,n); for i:=0 to n-1 do ReadLn(words[i]); ReadLn(width); ans:=Justify(words,width); WriteLn(Length(ans)); for i:=0 to High(ans) do WriteLn('|', ans[i], '|'); if tc<t then WriteLn('='); end; end.
