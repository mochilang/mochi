// MEP-16 R1: auto-wrap also applies to struct types. A `Person` value
// flows into a `Person?` slot, then narrowing inside `if p != none`
// recovers the wrapped struct so its fields can be read.
type Person { name: string }
let alice = Person{ name: "alice" }
let p: Person? = alice
let label = if p != none { p.name } else { "unknown" }
expect label == "alice"
