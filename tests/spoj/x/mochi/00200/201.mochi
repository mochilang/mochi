// SPOJ POLYGAME - The Game of Polygons
// https://www.spoj.com/problems/POLYGAME/
// Leaf-removal game on the dual tree of a triangulated convex polygon.
// Player who cuts the black triangle (first one listed) wins.
//
// Key insight: the dual tree of the triangulation is a tree.
// The black triangle T0 has degree = number of its edges that are diagonals
// (not polygon edges). An edge (u,v) is a polygon edge iff v=u+1 or {u,v}={0,n-1}.
//
// First player wins iff:
//   (a) T0 is a leaf (degree <= 1 in dual tree), OR
//   (b) total number of triangles (n-2) is even (i.e., n is even).
// Otherwise second player wins.

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun isPolygonEdge(u: int, v: int, n: int): int {
  // u and v are vertex indices of the polygon (0..n-1)
  // Returns 1 if edge (u,v) is a polygon edge, 0 if it's a diagonal
  var a = u
  var b = v
  if a > b { let tmp = a; a = b; b = tmp }
  // a < b: polygon edge iff b == a+1 or (a==0 and b==n-1)
  if b == a + 1 { return 1 }
  if a == 0 && b == n - 1 { return 1 }
  return 0
}

fun main() {
  var tLine = input()
  while tLine == "" { tLine = input() }
  let t = int(tLine)
  var ti = 0
  while ti < t {
    var nLine = input()
    while nLine == "" { nLine = input() }
    let n = int(nLine)

    // Read first triangle (the black one, T0)
    var firstLine = input()
    while firstLine == "" { firstLine = input() }
    let p = split(firstLine)
    let a = int(p[0])
    let b = int(p[1])
    let c = int(p[2])

    // Count diagonal edges of T0 = degree of T0 in dual tree
    var deg = 0
    if isPolygonEdge(a, b, n) == 0 { deg = deg + 1 }
    if isPolygonEdge(b, c, n) == 0 { deg = deg + 1 }
    if isPolygonEdge(a, c, n) == 0 { deg = deg + 1 }

    // Skip remaining n-3 triangles
    var i = 1
    while i < n - 2 {
      var line = input()
      while line == "" { line = input() }
      i = i + 1
    }

    // First player wins iff T0 is a leaf (deg <= 1) OR (n-2) is even
    var wins = 0
    if deg <= 1 { wins = 1 }
    if (n - 2) % 2 == 0 { wins = 1 }

    if wins == 1 { print("YES") } else { print("NO") }
    ti = ti + 1
  }
}

main()
