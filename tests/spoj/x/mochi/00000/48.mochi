// Solution for SPOJ BEADS - Glass Beads
// https://www.spoj.com/problems/BEADS/
// Find lexicographically smallest rotation of a string.

fun minRotation(s: string): string {
  let n = len(s)
  let ss = s + s
  var best = 0
  var i = 1
  while i < n {
    // Compare rotation starting at i vs current best
    let ni = n + i
    var j = 0
    while j < n {
      let a = ss[best+j:best+j+1]
      let b = ss[i+j:i+j+1]
      if a < b { break }
      if a > b { best = i; break }
      j = j + 1
    }
    i = i + 1
  }
  return ss[best:best+n]
}

fun main() {
  let tLine = input()
  if tLine == "" { return }
  let t = int(tLine)
  for _ in 0..t {
    let s = input()
    print(minRotation(s))
  }
}

main()
