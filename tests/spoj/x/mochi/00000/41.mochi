// Solution for SPOJ WORDS1 - Play on Words
// https://www.spoj.com/problems/WORDS1/
// Check if words can be chained: Eulerian path/circuit in directed graph.

let aOrd = {
  "a":0,"b":1,"c":2,"d":3,"e":4,"f":5,"g":6,"h":7,"i":8,"j":9,
  "k":10,"l":11,"m":12,"n":13,"o":14,"p":15,"q":16,"r":17,"s":18,
  "t":19,"u":20,"v":21,"w":22,"x":23,"y":24,"z":25,
}

fun find(parent: list<int>, x: int): int {
  if parent[x] == x { return x }
  let r = find(parent, parent[x])
  parent[x] = r
  return r
}

fun union(parent: list<int>, a: int, b: int) {
  let ra = find(parent, a)
  let rb = find(parent, b)
  if ra != rb { parent[ra] = rb }
}

fun main() {
  let tLine = input()
  if tLine == "" { return }
  let t = int(tLine)
  for _ in 0..t {
    let n = int(input())
    var indeg: list<int> = []
    var outdeg: list<int> = []
    var parent: list<int> = []
    var used: list<bool> = []
    var i = 0
    while i < 26 {
      indeg = append(indeg, 0)
      outdeg = append(outdeg, 0)
      parent = append(parent, i)
      used = append(used, false)
      i = i + 1
    }
    i = 0
    while i < n {
      let w = input()
      let u = aOrd[w[0:1]] as int
      let v = aOrd[w[len(w)-1:len(w)]] as int
      outdeg[u] = outdeg[u] + 1
      indeg[v] = indeg[v] + 1
      used[u] = true
      used[v] = true
      union(parent, u, v)
      i = i + 1
    }
    // Check connectivity: all used nodes must have same root
    var root = 0 - 1
    var connected = true
    var k = 0
    while k < 26 {
      if used[k] {
        let r = find(parent, k)
        if root == 0 - 1 { root = r }
        else if r != root { connected = false }
      }
      k = k + 1
    }
    // Check Euler conditions
    var startNodes = 0
    var endNodes = 0
    var ok = true
    k = 0
    while k < 26 {
      if used[k] {
        let diff = outdeg[k] - indeg[k]
        if diff == 1 { startNodes = startNodes + 1 }
        else if diff == 0 - 1 { endNodes = endNodes + 1 }
        else if diff != 0 { ok = false }
      }
      k = k + 1
    }
    let euler = (startNodes == 0 && endNodes == 0) || (startNodes == 1 && endNodes == 1)
    if connected && euler && ok {
      print("Ordering is possible.")
    } else {
      print("The door cannot be opened.")
    }
  }
}

main()
