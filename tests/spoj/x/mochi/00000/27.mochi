// Solution for SPOJ SBANK - Sorting Bank Accounts
// https://www.spoj.com/problems/SBANK/

fun sortStrings(arr: list<string>): list<string> {
  let n = len(arr)
  var i = 1
  while i < n {
    let key = arr[i]
    var j = i - 1
    while j >= 0 && arr[j] > key {
      arr[j+1] = arr[j]
      j = j - 1
    }
    arr[j+1] = key
    i = i + 1
  }
  return arr
}

fun main() {
  let tLine = input()
  if tLine == "" { return }
  let t = int(tLine)
  var caseIdx = 0
  while caseIdx < t {
    // skip blank separator lines
    var nLine = input()
    while nLine == "" { nLine = input() }
    let n = int(nLine)
    var accounts: list<string> = []
    var i = 0
    while i < n {
      accounts = append(accounts, input())
      i = i + 1
    }
    accounts = sortStrings(accounts)
    for acc in accounts {
      print(acc)
    }
    print("")
    caseIdx = caseIdx + 1
  }
}

main()
