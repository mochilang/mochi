// Solution for SPOJ PIR - Pyramids
// https://www.spoj.com/problems/PIR/
// Given square pyramid with base side a and height h, compute volume.
// Volume = (1/3) * a^2 * h

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun fmtDecimal(x: float, places: int): string {
  var mult = 1.0
  var i = 0
  while i < places { mult = mult * 10.0; i = i + 1 }
  let scaled = int(x * mult + 0.5)
  let imult = int(mult)
  let intPart = int(scaled / imult)
  let fracPart = scaled % imult
  var fracStr = str(fracPart)
  while len(fracStr) < places { fracStr = "0" + fracStr }
  return str(intPart) + "." + fracStr
}

fun main() {
  let tLine = input()
  if tLine == "" { return }
  let t = int(tLine)
  for _ in 0..t {
    let p = split(input())
    let a = int(p[0]) as float
    let h = int(p[1]) as float
    let vol = a * a * h / 3.0
    print(fmtDecimal(vol, 4))
  }
}

main()
