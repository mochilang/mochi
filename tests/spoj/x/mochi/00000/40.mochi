// Solution for SPOJ STONE - Lifting the Stone
// https://www.spoj.com/problems/STONE/
// Centroid of a homogeneous polygon using the shoelace formula.

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun fmtDecimal(x: float, places: int): string {
  var neg = 0
  if x < 0.0 { neg = 1; x = 0.0 - x }
  var mult = 1.0
  var i = 0
  while i < places { mult = mult * 10.0; i = i + 1 }
  let scaled = int(x * mult + 0.5)
  let imult = int(mult)
  let intPart = int(scaled / imult)
  let fracPart = scaled % imult
  var fracStr = str(fracPart)
  while len(fracStr) < places { fracStr = "0" + fracStr }
  var res = str(intPart) + "." + fracStr
  if neg == 1 { res = "-" + res }
  return res
}

fun main() {
  var tLine = input()
  while tLine == "" { tLine = input() }
  let t = int(tLine)
  var ti = 0
  while ti < t {
    var nLine = input()
    while nLine == "" { nLine = input() }
    let n = int(nLine)

    var xs: list<float> = []
    var ys: list<float> = []
    var vi = 0
    while vi < n {
      var vLine = input()
      while vLine == "" { vLine = input() }
      let p = split(vLine)
      xs = append(xs, int(p[0]) as float)
      ys = append(ys, int(p[1]) as float)
      vi = vi + 1
    }

    var area = 0.0
    var cx = 0.0
    var cy = 0.0
    var i = 0
    while i < n {
      let j = (i + 1) % n
      let cross = xs[i] * ys[j] - xs[j] * ys[i]
      area = area + cross
      cx = cx + (xs[i] + xs[j]) * cross
      cy = cy + (ys[i] + ys[j]) * cross
      i = i + 1
    }
    area = area / 2.0
    if area < 0.0 { area = 0.0 - area }
    cx = cx / (6.0 * area)
    cy = cy / (6.0 * area)

    print(fmtDecimal(cx, 2) + " " + fmtDecimal(cy, 2))
    ti = ti + 1
  }
}

main()
