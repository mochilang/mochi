// Solution for SPOJ IMP - The Imp
// https://www.spoj.com/problems/IMP/
// Find minimum |x|+|y| of a non-zero point reachable from (0,0) using
// moves (a,b),(-a,-b),(c,d),(-c,-d) (i.e., lattice generated by (a,b) and (c,d)).
// Use Gauss lattice basis reduction with L1 norm.

fun split(s: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(s) {
    if s[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + s[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun absval(x: int): int {
  if x < 0 { return -x }
  return x
}

fun l1(a: int, b: int): int {
  return absval(a) + absval(b)
}

// Floor division (toward -infinity)
fun floordiv(a: int, b: int): int {
  let q = int(a / b)
  // Adjust if sign differs and there's a remainder
  if (a % b != 0) && ((a < 0) != (b < 0)) {
    return q - 1
  }
  return q
}

// Find k minimizing |vc - k*ua| + |vd - k*ub|
fun bestK(ua: int, ub: int, vc: int, vd: int): int {
  // Collect candidate k values
  var cands: list<int> = [0, 1, -1]
  if ua != 0 {
    let k0 = floordiv(vc, ua)
    cands = append(cands, k0)
    cands = append(cands, k0 + 1)
    cands = append(cands, k0 - 1)
  }
  if ub != 0 {
    let k0 = floordiv(vd, ub)
    cands = append(cands, k0)
    cands = append(cands, k0 + 1)
    cands = append(cands, k0 - 1)
  }
  var bestK = 0
  var bestL = l1(vc, vd)
  var i = 0
  while i < len(cands) {
    let k = cands[i]
    let lv = l1(vc - k * ua, vd - k * ub)
    if lv < bestL {
      bestL = lv
      bestK = k
    }
    i = i + 1
  }
  return bestK
}

fun solve(a: int, b: int, c: int, d: int): int {
  // Basis vectors u=(a,b), v=(c,d)
  var ua = a
  var ub = b
  var vc = c
  var vd = d

  // Gauss-like reduction
  var iters = 0
  while iters < 1000 {
    iters = iters + 1
    // Ensure u has smaller or equal L1
    if l1(ua, ub) > l1(vc, vd) {
      let ta = ua; let tb = ub
      ua = vc; ub = vd
      vc = ta; vd = tb
    }
    // If u is zero, lattice is just multiples of v
    if ua == 0 && ub == 0 {
      return l1(vc, vd)
    }
    // Reduce v by best multiple of u
    let k = bestK(ua, ub, vc, vd)
    let newvc = vc - k * ua
    let newvd = vd - k * ub
    if l1(newvc, newvd) >= l1(vc, vd) {
      // No further reduction possible
      break
    }
    vc = newvc
    vd = newvd
  }
  return l1(ua, ub)
}

fun main() {
  var ti = 0
  while ti < 10 {
    var line = input()
    while line == "" { line = input() }
    let p = split(line)
    let a = int(p[0])
    let b = int(p[1])
    let c = int(p[2])
    let d = int(p[3])
    print(solve(a, b, c, d))
    ti = ti + 1
  }
}

main()
