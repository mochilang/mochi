// Solution for SPOJ HOTLINE - Telephone Lines MST
// https://www.spoj.com/problems/HOTLINE/
// Find minimum spanning tree cost using Kruskal's algorithm with union-find.

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

// Union-Find: find root with path compression (iterative)
fun findRoot(parent: list<int>, x: int): int {
  while parent[x] != x {
    parent[x] = parent[parent[x]]
    x = parent[x]
  }
  return x
}

fun main() {
  var firstLine = input()
  while firstLine != "" {
    let nm = split(firstLine)
    let n = int(nm[0])
    let m = int(nm[1])
    if n == 0 && m == 0 { break }

    // Read edges
    var eu: list<int> = []
    var ev: list<int> = []
    var ew: list<int> = []
    var i = 0
    while i < m {
      let parts = split(input())
      eu = append(eu, int(parts[0]) - 1)
      ev = append(ev, int(parts[1]) - 1)
      ew = append(ew, int(parts[2]))
      i = i + 1
    }

    // Sort edges by weight (insertion sort)
    i = 1
    while i < m {
      var j = i
      while j > 0 && ew[j] < ew[j-1] {
        let tw = ew[j]; ew[j] = ew[j-1]; ew[j-1] = tw
        let tu = eu[j]; eu[j] = eu[j-1]; eu[j-1] = tu
        let tv = ev[j]; ev[j] = ev[j-1]; ev[j-1] = tv
        j = j - 1
      }
      i = i + 1
    }

    // Union-Find
    var parent: list<int> = []
    var rank: list<int> = []
    i = 0
    while i < n {
      parent = append(parent, i)
      rank = append(rank, 0)
      i = i + 1
    }

    var totalCost = 0
    var edgesUsed = 0
    i = 0
    while i < m && edgesUsed < n - 1 {
      let u = eu[i]
      let v = ev[i]
      let w = ew[i]
      let ru = findRoot(parent, u)
      let rv = findRoot(parent, v)
      if ru != rv {
        // Union by rank
        if rank[ru] < rank[rv] {
          parent[ru] = rv
        } else {
          if rank[ru] > rank[rv] {
            parent[rv] = ru
          } else {
            parent[rv] = ru
            rank[ru] = rank[ru] + 1
          }
        }
        totalCost = totalCost + w
        edgesUsed = edgesUsed + 1
      }
      i = i + 1
    }

    print(totalCost)
    firstLine = input()
  }
}

main()
