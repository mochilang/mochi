// Solution for SPOJ FCTRL - Factorial
// https://www.spoj.com/problems/FCTRL/
// Count trailing zeros in n! = sum of floor(n/5^k) for k=1,2,...

fun trailingZeros(n: int): int {
  var count = 0
  var p = 5
  while p <= n {
    count = count + int(n / p)
    p = p * 5
  }
  return count
}

fun main() {
  let tLine = input()
  if tLine == "" { return }
  let t = int(tLine)
  for _ in 0..t {
    let line = input()
    let n = int(line)
    print(trailingZeros(n))
  }
}

main()
