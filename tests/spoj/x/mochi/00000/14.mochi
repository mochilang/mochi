// Solution for SPOJ IKEYB - I-Keyboard
// https://www.spoj.com/problems/IKEYB/
// Assign 26 letters to K keys (each with given capacity) to minimize total keystrokes.
// Greedy: sort letter frequencies descending, sort key positions (1,2,...,size[k] for each k)
// ascending, then match them in order.

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun main() {
  var tLine = input()
  let t = int(tLine)
  var ti = 0
  while ti < t {
    let k = int(input())
    let szParts = split(input())
    let freqParts = split(input())

    // Read key sizes
    var sizes: list<int> = []
    var i = 0
    while i < k {
      sizes = append(sizes, int(szParts[i]))
      i = i + 1
    }

    // Read letter frequencies
    var freqs: list<int> = []
    i = 0
    while i < 26 {
      freqs = append(freqs, int(freqParts[i]))
      i = i + 1
    }

    // Sort frequencies descending (insertion sort)
    i = 1
    while i < 26 {
      var j = i
      while j > 0 && freqs[j] > freqs[j-1] {
        let tmp = freqs[j]; freqs[j] = freqs[j-1]; freqs[j-1] = tmp
        j = j - 1
      }
      i = i + 1
    }

    // Sort key sizes descending (insertion sort)
    i = 1
    while i < k {
      var j = i
      while j > 0 && sizes[j] > sizes[j-1] {
        let tmp = sizes[j]; sizes[j] = sizes[j-1]; sizes[j-1] = tmp
        j = j - 1
      }
      i = i + 1
    }

    // Build sorted list of positions across all keys
    // positions are 1-indexed within each key, produced in ascending order per key
    // Then merge-sort or just insert into a sorted positions list
    // Since key sizes are sorted descending, we generate positions key by key
    // and then sort the combined list ascending
    var positions: list<int> = []
    i = 0
    while i < k {
      var p = 1
      while p <= sizes[i] {
        positions = append(positions, p)
        p = p + 1
      }
      i = i + 1
    }

    // Sort positions ascending (insertion sort)
    let np = len(positions)
    i = 1
    while i < np {
      var j = i
      while j > 0 && positions[j] < positions[j-1] {
        let tmp = positions[j]; positions[j] = positions[j-1]; positions[j-1] = tmp
        j = j - 1
      }
      i = i + 1
    }

    // Assign: letter with highest freq gets lowest position
    var total = 0
    i = 0
    while i < 26 && i < np {
      total = total + freqs[i] * positions[i]
      i = i + 1
    }

    print(total)
    ti = ti + 1
  }
}

main()
