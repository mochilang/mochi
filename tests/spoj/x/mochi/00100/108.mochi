// Solution for SPOJ MORSE - Decoding Morse Sequences
// https://www.spoj.com/problems/MORSE/
// DP: dp[i] = number of ways to parse morse[0..i-1]
// For each position, try all dictionary word morse codes.

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun letterMorse(c: string): string {
  if c == "A" { return ".-" }
  if c == "B" { return "-..." }
  if c == "C" { return "-.-." }
  if c == "D" { return "-.." }
  if c == "E" { return "." }
  if c == "F" { return "..-." }
  if c == "G" { return "--." }
  if c == "H" { return "...." }
  if c == "I" { return ".." }
  if c == "J" { return ".---" }
  if c == "K" { return "-.-" }
  if c == "L" { return ".-.." }
  if c == "M" { return "--" }
  if c == "N" { return "-." }
  if c == "O" { return "---" }
  if c == "P" { return ".--." }
  if c == "Q" { return "--.-" }
  if c == "R" { return ".-." }
  if c == "S" { return "..." }
  if c == "T" { return "-" }
  if c == "U" { return "..-" }
  if c == "V" { return "...-" }
  if c == "W" { return ".--" }
  if c == "X" { return "-..-" }
  if c == "Y" { return "-.--" }
  if c == "Z" { return "--.." }
  return ""
}

fun wordToMorse(word: string): string {
  var result = ""
  var i = 0
  while i < len(word) {
    result = result + letterMorse(word[i:i+1])
    i = i + 1
  }
  return result
}

fun main() {
  let dLine = input()
  let d = int(dLine)
  var t = 0
  while t < d {
    let morse = input()
    let nLine = input()
    let n = int(nLine)

    // Collect all unique morse encodings of dictionary words
    // Use a map from morse-code -> true to deduplicate
    var codeMap: map<string, bool> = {}
    var i = 0
    while i < n {
      let word = input()
      let mc = wordToMorse(word)
      codeMap[mc] = true
      i = i + 1
    }

    // Build list of codes and their lengths
    var codes: list<string> = []
    var codeLens: list<int> = []
    for k in codeMap {
      codes = append(codes, k)
      codeLens = append(codeLens, len(k))
    }

    let mLen = len(morse)

    // dp[i] = number of ways to parse morse[0..i-1]
    var dp: list<int> = []
    var j = 0
    while j <= mLen {
      dp = append(dp, 0)
      j = j + 1
    }
    dp[0] = 1

    j = 0
    while j < mLen {
      if dp[j] > 0 {
        var ci = 0
        while ci < len(codes) {
          let clen = codeLens[ci]
          if j + clen <= mLen {
            if morse[j:j+clen] == codes[ci] {
              dp[j + clen] = dp[j + clen] + dp[j]
            }
          }
          ci = ci + 1
        }
      }
      j = j + 1
    }

    print(str(dp[mLen]))
    t = t + 1
  }
}

main()
