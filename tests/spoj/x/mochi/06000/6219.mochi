// Solution for SPOJ EDIST - Edit Distance
// https://www.spoj.com/problems/EDIST/
// Standard Levenshtein DP: dp[i][j] = min edits to turn s[0..i) into t[0..j).

fun main() {
  var tLine = input()
  while tLine == "" { tLine = input() }
  let T = int(tLine)
  var ti = 0
  while ti < T {
    var s = input()
    while s == "" { s = input() }
    var t = input()
    while t == "" { t = input() }

    let m = len(s)
    let n = len(t)
    let cols = n + 1

    // dp flat list of (m+1)*(n+1)
    var dp: list<int> = []
    var idx = 0
    while idx < (m+1) * (n+1) { dp = append(dp, 0); idx = idx + 1 }

    // base cases
    var i = 0
    while i <= m { dp[i*cols+0] = i; i = i + 1 }
    var j = 0
    while j <= n { dp[0*cols+j] = j; j = j + 1 }

    i = 1
    while i <= m {
      j = 1
      while j <= n {
        var cost = 1
        if s[i-1:i] == t[j-1:j] { cost = 0 }
        let del = dp[(i-1)*cols+j] + 1
        let ins = dp[i*cols+(j-1)] + 1
        let rep = dp[(i-1)*cols+(j-1)] + cost
        var best = del
        if ins < best { best = ins }
        if rep < best { best = rep }
        dp[i*cols+j] = best
        j = j + 1
      }
      i = i + 1
    }

    print(dp[m*cols+n])
    ti = ti + 1
  }
}

main()
