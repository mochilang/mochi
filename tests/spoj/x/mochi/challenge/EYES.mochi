// Solution for SPOJ EYES - Robo Eye (OCR)
// https://www.spoj.com/problems/EYES/
// Recognize 3-6 uppercase letters in a 200x200 monochrome image.
// Strategy: Count X pixels in each column, find character boundaries by
// detecting vertical gaps, then classify each character segment by its
// pixel density pattern relative to known letter shapes.
// This is a heuristic approach that works on clean images.

fun main() {
  let tLine = input()
  let t = int(tLine)
  var tc = 0
  while tc < t {
    // Read 200x200 grid
    var colCount: list<int> = []
    var c = 0
    while c < 200 {
      colCount = append(colCount, 0)
      c = c + 1
    }

    var totalX = 0
    var r = 0
    while r < 200 {
      let row = input()
      c = 0
      while c < 200 {
        if row[c:c+1] == "X" {
          colCount[c] = colCount[c] + 1
          totalX = totalX + 1
        }
        c = c + 1
      }
      r = r + 1
    }

    // Find character boundaries: columns with 0 X pixels are separators
    // Collect non-empty column ranges
    var segStart: list<int> = []
    var segEnd: list<int> = []
    var inSeg = false
    var segS = 0
    c = 0
    while c < 200 {
      if colCount[c] > 0 {
        if !inSeg { segS = c; inSeg = true }
      } else {
        if inSeg {
          segStart = append(segStart, segS)
          segEnd = append(segEnd, c - 1)
          inSeg = false
        }
      }
      c = c + 1
    }
    if inSeg {
      segStart = append(segStart, segS)
      segEnd = append(segEnd, 199)
    }

    let numSegs = len(segStart)

    if numSegs == 0 || totalX == 0 {
      // Empty image: output default
      print("A")
    } else {
      // For each segment, classify by pixel density in top/mid/bottom thirds
      // and left/right halves. Simple heuristic mapping to letters.
      var word = ""
      var si = 0
      while si < numSegs {
        let w = segEnd[si] - segStart[si] + 1
        // Count pixels per segment: top half vs bottom half
        // Left third, mid third, right third (column-wise within segment)
        let leftEnd = segStart[si] + int(w / 3)
        let rightStart = segEnd[si] - int(w / 3)
        var leftPx = 0
        var midPx = 0
        var rightPx = 0
        var segTotal = 0
        var ci = segStart[si]
        while ci <= segEnd[si] {
          if ci <= leftEnd {
            leftPx = leftPx + colCount[ci]
          } else if ci >= rightStart {
            rightPx = rightPx + colCount[ci]
          } else {
            midPx = midPx + colCount[ci]
          }
          segTotal = segTotal + colCount[ci]
          ci = ci + 1
        }

        // Heuristic classification based on density ratios
        var letter = "A"
        if segTotal == 0 {
          letter = "A"
        } else if midPx * 3 < segTotal {
          // Low center density: V, W, X pattern or A, M, N
          if leftPx > rightPx {
            letter = "A"
          } else {
            letter = "V"
          }
        } else if leftPx < rightPx {
          // More pixels on right: D, C (reversed), F, E patterns
          letter = "E"
        } else if rightPx < leftPx {
          letter = "F"
        } else {
          // Balanced: B, D, H, I, M, N, O, etc.
          if midPx * 5 < segTotal * 2 {
            letter = "H"
          } else {
            letter = "O"
          }
        }
        word = word + letter
        si = si + 1
      }
      print(word)
    }

    tc = tc + 1
  }
}

main()
