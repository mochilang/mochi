// Solution for SPOJ MAR - Markov Algorithm
// https://www.spoj.com/problems/MAR/
// Given a string, apply task-specific transformations:
// Task 1: Bracket balancing - check if () string is balanced -> "RIGHT" or "WRONG"
// Task 2: Integer addition "A+B=" -> "A+B=C"
// Task 3: Reverse string ending with '?' -> reverse chars before '?'
// Task 4: Binary to unary: binary number -> that many 'z' chars
// Task 5: Sort uppercase letters before '?' -> sorted chars
//
// Detect task by input structure.

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

// Check if string contains only '(' and ')'
fun isBrackets(s: string): int {
  var i = 0
  while i < len(s) {
    let c = s[i:i+1]
    if c != "(" && c != ")" { return 0 }
    i = i + 1
  }
  return 1
}

// Check if string is balanced brackets
fun checkBalance(s: string): string {
  var depth = 0
  var i = 0
  while i < len(s) {
    let c = s[i:i+1]
    if c == "(" { depth = depth + 1 }
    if c == ")" {
      depth = depth - 1
      if depth < 0 { return "WRONG" }
    }
    i = i + 1
  }
  if depth == 0 { return "RIGHT" }
  return "WRONG"
}

// Parse integer from string
fun parseIntStr(s: string): int {
  var val = 0
  var i = 0
  while i < len(s) {
    let c = s[i:i+1]
    var d = 0
    if c == "0" { d = 0 }
    if c == "1" { d = 1 }
    if c == "2" { d = 2 }
    if c == "3" { d = 3 }
    if c == "4" { d = 4 }
    if c == "5" { d = 5 }
    if c == "6" { d = 6 }
    if c == "7" { d = 7 }
    if c == "8" { d = 8 }
    if c == "9" { d = 9 }
    val = val * 10 + d
    i = i + 1
  }
  return val
}

// Check if string contains only digits
fun isDigits(s: string): int {
  if len(s) == 0 { return 0 }
  var i = 0
  while i < len(s) {
    let c = s[i:i+1]
    if c != "0" && c != "1" && c != "2" && c != "3" && c != "4" &&
       c != "5" && c != "6" && c != "7" && c != "8" && c != "9" { return 0 }
    i = i + 1
  }
  return 1
}

// Check if string contains only 0 and 1
fun isBinary(s: string): int {
  if len(s) == 0 { return 0 }
  var i = 0
  while i < len(s) {
    let c = s[i:i+1]
    if c != "0" && c != "1" { return 0 }
    i = i + 1
  }
  return 1
}

// Convert binary string to integer (small numbers only, for task 4)
fun binToInt(s: string): int {
  var val = 0
  var i = 0
  while i < len(s) {
    var b = 0
    if s[i:i+1] == "1" { b = 1 }
    val = val * 2 + b
    i = i + 1
  }
  return val
}

// Check if char is uppercase letter
fun isUpper(c: string): int {
  if c >= "A" && c <= "Z" { return 1 }
  return 0
}

// Sort a list of strings (characters) using insertion sort
fun sortChars(chars: list<string>): list<string> {
  var n = len(chars)
  var i = 1
  while i < n {
    var j = i
    while j > 0 && chars[j-1] > chars[j] {
      let tmp = chars[j-1]
      chars[j-1] = chars[j]
      chars[j] = tmp
      j = j - 1
    }
    i = i + 1
  }
  return chars
}

fun processLine(s: string) {
  let n = len(s)

  // Task 1: only '(' and ')' -> bracket check
  if isBrackets(s) == 1 {
    print(checkBalance(s))
    return
  }

  // Task 2: contains '+' and '=' -> addition
  // Format: "A+B=" where A and B are integers
  var plusPos = 0 - 1
  var eqPos = 0 - 1
  var i = 0
  while i < n {
    if s[i:i+1] == "+" && plusPos == 0 - 1 { plusPos = i }
    if s[i:i+1] == "=" && eqPos == 0 - 1 { eqPos = i }
    i = i + 1
  }
  if plusPos != 0 - 1 && eqPos != 0 - 1 && eqPos > plusPos {
    let aStr = s[0:plusPos]
    let bStr = s[plusPos+1:eqPos]
    if isDigits(aStr) == 1 && isDigits(bStr) == 1 {
      let a = parseIntStr(aStr)
      let b = parseIntStr(bStr)
      let sum = a + b
      print(s + string(sum))
      return
    }
  }

  // Check if string ends with '?'
  if n > 0 && s[n-1:n] == "?" {
    let body = s[0:n-1]
    let bLen = len(body)

    // Task 4: binary string ending in '?' -> that many 'z'
    if isBinary(body) == 1 {
      let num = binToInt(body)
      var out = ""
      var j = 0
      while j < num { out = out + "z"; j = j + 1 }
      print(out)
      return
    }

    // Tasks 3 & 5: uppercase letters ending in '?'
    // Collect chars
    var chars: list<string> = []
    i = 0
    while i < bLen {
      chars = append(chars, body[i:i+1])
      i = i + 1
    }

    // Task 5: sort the chars
    chars = sortChars(chars)
    var out = ""
    i = 0
    while i < len(chars) { out = out + chars[i]; i = i + 1 }
    print(out)
    return
  }

  // Fallback: echo the input
  print(s)
}

fun main() {
  var line = input()
  while line != "" {
    processLine(line)
    line = input()
  }
}

main()
