// Solution for SPOJ FINDPROB - Find New SPOJ Problems
// https://www.spoj.com/problems/FINDPROB/
// Parse HTML pages to find unsolved problems that competitors have solved.

fun containsCode(codes: list<string>, code: string): int {
  var i = 0
  while i < len(codes) {
    if codes[i] == code { return 1 }
    i = i + 1
  }
  return 0
}

fun extractCodes(line: string): list<string> {
  var codes: list<string> = []
  var pat = "/problems/"
  var plen = len(pat)
  var i = 0
  while i < len(line) {
    if i + plen <= len(line) {
      var seg = line[i:i+plen]
      if seg == pat {
        var code = ""
        var k = i + plen
        while k < len(line) {
          var ch = line[k:k+1]
          if ch == "/" { k = len(line) }
          else if ch == "\"" { k = len(line) }
          else if ch == ">" { k = len(line) }
          else {
            code = code + ch
            k = k + 1
          }
        }
        if len(code) > 0 {
          codes = append(codes, code)
        }
        i = i + plen
      } else {
        i = i + 1
      }
    } else {
      i = i + 1
    }
  }
  return codes
}

// Read your page until we hit a line that is a plain integer (competitor count)
var myLines: list<string> = []
var compCount = -1
var line = input()
while compCount == -1 {
  var parsed = int(line)
  // Check if line is purely the competitor count: try parse and verify
  // A line is the count line if it equals str(parsed) and parsed >= 0
  if str(parsed) == line {
    compCount = parsed
  } else {
    myLines = append(myLines, line)
    line = input()
}
}

// Extract my solved codes
var myCodes: list<string> = []
var mi = 0
while mi < len(myLines) {
  var extracted = extractCodes(myLines[mi])
  var ei = 0
  while ei < len(extracted) {
    var code = extracted[ei]
    if containsCode(myCodes, code) == 0 {
      myCodes = append(myCodes, code)
    }
    ei = ei + 1
  }
  mi = mi + 1
}

// Read competitor pages and track codes + counts
var compCodes: list<string> = []
var compCounts: list<int> = []

var ci = 0
while ci < compCount {
  var cline = input()
  var cExtracted = extractCodes(cline)
  var cei = 0
  while cei < len(cExtracted) {
    var code = cExtracted[cei]
    if containsCode(myCodes, code) == 0 {
      // Find in compCodes
      var fi = 0
      var found = 0
      while fi < len(compCodes) {
        if compCodes[fi] == code {
          compCounts[fi] = compCounts[fi] + 1
          found = 1
          fi = len(compCodes)
        }
        fi = fi + 1
      }
      if found == 0 {
        compCodes = append(compCodes, code)
        compCounts = append(compCounts, 1)
      }
    }
    cei = cei + 1
  }
  ci = ci + 1
}

// Insertion sort: descending by count, then ascending alphabetically
var si = 1
while si < len(compCodes) {
  var keyCode = compCodes[si]
  var keyCnt = compCounts[si]
  var sj = si - 1
  var insertPos = 0
  var done = 0
  while sj >= 0 {
    if done == 0 {
      var swap = 0
      if compCounts[sj] < keyCnt { swap = 1 }
      else if compCounts[sj] == keyCnt {
        if compCodes[sj] > keyCode { swap = 1 }
      }
      if swap == 1 {
        compCodes[sj+1] = compCodes[sj]
        compCounts[sj+1] = compCounts[sj]
        insertPos = sj
        sj = sj - 1
      } else {
        insertPos = sj + 1
        done = 1
        sj = -1
      }
    }
  }
  compCodes[insertPos] = keyCode
  compCounts[insertPos] = keyCnt
  si = si + 1
}

// Output
var oi = 0
while oi < len(compCodes) {
  print(compCodes[oi])
  oi = oi + 1
}
