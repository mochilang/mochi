// SPOJ CDGLF1 - Kejriwal And Broom
// Negative-priced brooms: owner pays Kejriwal. Take up to m brooms with most-negative prices.

fun split(s: string): list<string> {
  var r: list<string> = []
  var c = ""
  var i = 0
  while i < len(s) {
    if s[i:i+1] == " " {
      if len(c) > 0 { r = append(r, c); c = "" }
    } else { c = c + s[i:i+1] }
    i = i + 1
  }
  if len(c) > 0 { r = append(r, c) }
  return r
}

fun main() {
  let t = int(input())
  var tc = 0
  while tc < t {
    let p = split(input())
    let n = int(p[0])
    let m = int(p[1])
    let vals = split(input())
    var a: list<int> = []
    var i = 0
    while i < n { a = append(a, int(vals[i])); i = i + 1 }
    // insertion sort ascending
    i = 1
    while i < n {
      var j = i
      while j > 0 && a[j] < a[j-1] {
        let tmp = a[j]; a[j] = a[j-1]; a[j-1] = tmp
        j = j - 1
      }
      i = i + 1
    }
    var sum = 0
    var k = 0
    while k < m {
      if a[k] < 0 { sum = sum - a[k] }
      k = k + 1
    }
    print(sum)
    tc = tc + 1
  }
}

main()
