// SPOJ CDGLF3 - Mr Phoenix And OR Operation
// For each right endpoint r, maintain list of distinct OR values of subarrays ending at r.
// At most log(max_val) such values. Count globally distinct OR values.
// Bitwise OR via arithmetic; use string keys to avoid VM map-persistence bug.

fun split(s: string): list<string> {
  var r: list<string> = []
  var c = ""
  var i = 0
  while i < len(s) {
    if s[i:i+1] == " " {
      if len(c) > 0 { r = append(r, c); c = "" }
    } else { c = c + s[i:i+1] }
    i = i + 1
  }
  if len(c) > 0 { r = append(r, c) }
  return r
}

fun bitor(a: int, b: int): int {
  var res = 0
  var p = 1
  var i = 0
  while i < 20 {
    if a % 2 == 1 || b % 2 == 1 { res = res + p }
    a = int(a / 2)
    b = int(b / 2)
    p = p * 2
    i = i + 1
  }
  return res
}

fun main() {
  let t = int(input())
  var tc = 0
  var seen: map<string, int> = {}
  while tc < t {
    let pfx = str(tc) + "_"
    let n = int(input())
    let nums = split(input())
    var count = 0
    var cur: list<int> = []
    var i = 0
    while i < n {
      let x = int(nums[i])
      var next: list<int> = []
      var j = 0
      while j < len(cur) {
        let v = bitor(cur[j], x)
        if len(next) == 0 {
          next = append(next, v)
        } else if next[len(next)-1] != v {
          next = append(next, v)
        }
        j = j + 1
      }
      if len(next) == 0 {
        next = append(next, x)
      } else if next[len(next)-1] != x {
        next = append(next, x)
      }
      cur = next
      var k = 0
      while k < len(cur) {
        let key = pfx + str(cur[k])
        if seen[key] == nil { count = count + 1; seen[key] = 1 }
        k = k + 1
      }
      i = i + 1
    }
    print(count)
    tc = tc + 1
  }
}

main()
