// Solution for SPOJ TONES - Tone Transposition
// https://www.spoj.com/problems/TONES/
// Transpose n chords by t semitones. Notes: C C# D D# E F F# G G# A A# B

fun split(s: string): list<string> {
  var r: list<string> = []
  var c = ""
  var i = 0
  while i < len(s) {
    if s[i:i+1] == " " {
      if len(c) > 0 { r = append(r, c); c = "" }
    } else { c = c + s[i:i+1] }
    i = i + 1
  }
  if len(c) > 0 { r = append(r, c) }
  return r
}

// notes list: index = semitone value
let notes: list<string> = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"]

fun noteIdx(name: string): int {
  var i = 0
  while i < 12 {
    if notes[i] == name { return i }
    i = i + 1
  }
  return 0
}

fun transpose(chord: string, t: int): string {
  // Parse root: first char, maybe followed by '#'
  var root = chord[0:1]
  var rest = chord[1:]
  if len(rest) > 0 && rest[0:1] == "#" {
    root = root + "#"
    rest = rest[1:]
  }
  let idx = (noteIdx(root) + t) % 12
  return notes[idx] + rest
}

fun main() {
  var nLine = input()
  while nLine != "" {
    let n = int(nLine)
    if n == 0 { return }
    var tLine = input()
    let t = ((int(tLine) % 12) + 12) % 12
    let chords = split(input())
    var i = 0
    while i < n {
      print(transpose(chords[i], t))
      i = i + 1
    }
    nLine = input()
  }
}

main()
