// Solution for SPOJ CEBITO - The Secret Recipe
// https://www.spoj.com/problems/CEBITO/
// Greedy DFS from root: visit witches in DFS pre-order, sorting children by
// ascending subtree weight (total chat time) for better worst-case score.
// The flat output format: for each witch visited, print her name, then for
// each of her children: print child name (response token) and recurse.

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

// Parse witch name (exactly 5 letters) from the start of a line
fun parseName(line: string): string {
  return line[0:5]
}

// Parse chat minutes from a witch description line.
// Root format: "Name chats X min."
// Child format: "Name is the daughter of Mother and chats X min."
// We find "chats " and extract the number following it.
fun parseChatTime(line: string): int {
  // Find "chats " in the line
  var i = 0
  var found = 0
  var start = 0
  while i < len(line) - 5 {
    if line[i:i+6] == "chats " {
      found = 1
      start = i + 6
      break
    }
    i = i + 1
  }
  if found == 0 { return 1 }
  // Parse digits from start
  var val = 0
  var j = start
  while j < len(line) {
    let ch = line[j:j+1]
    if ch == "0" { val = val * 10 + 0; j = j + 1 }
    else if ch == "1" { val = val * 10 + 1; j = j + 1 }
    else if ch == "2" { val = val * 10 + 2; j = j + 1 }
    else if ch == "3" { val = val * 10 + 3; j = j + 1 }
    else if ch == "4" { val = val * 10 + 4; j = j + 1 }
    else if ch == "5" { val = val * 10 + 5; j = j + 1 }
    else if ch == "6" { val = val * 10 + 6; j = j + 1 }
    else if ch == "7" { val = val * 10 + 7; j = j + 1 }
    else if ch == "8" { val = val * 10 + 8; j = j + 1 }
    else if ch == "9" { val = val * 10 + 9; j = j + 1 }
    else { break }
  }
  return val
}

// Parse mother name from child format: "Name is the daughter of Mother and chats X min."
// Mother name is 5 letters starting after "of "
fun parseMotherName(line: string): string {
  // Find "of " in the line
  var i = 0
  while i < len(line) - 2 {
    if line[i:i+3] == "of " {
      return line[i+3:i+8]
    }
    i = i + 1
  }
  return ""
}

fun main() {
  let k = int(input())

  // Read all k witches
  var names: list<string> = []
  var chatTimes: list<int> = []
  var parentName: list<string> = []
  var rootIdx = 0

  var wi = 0
  while wi < k {
    let line = input()
    let name = parseName(line)
    let chat = parseChatTime(line)
    names = append(names, name)
    chatTimes = append(chatTimes, chat)
    if wi == 0 {
      // Root witch: "Name chats X min."
      parentName = append(parentName, "")
      rootIdx = 0
    } else {
      let mother = parseMotherName(line)
      parentName = append(parentName, mother)
    }
    wi = wi + 1
  }

  // Build name -> index map
  var nameToIdx: map<string, int> = {}
  var ni = 0
  while ni < k {
    nameToIdx[names[ni]] = ni
    ni = ni + 1
  }

  // Count children per node
  var childCount: list<int> = []
  var ci = 0
  while ci < k { childCount = append(childCount, 0); ci = ci + 1 }
  var pi = 1
  while pi < k {
    let pIdx = nameToIdx[parentName[pi]] as int
    childCount[pIdx] = childCount[pIdx] + 1
    pi = pi + 1
  }

  // Build child_start (prefix sums)
  var childStart: list<int> = []
  childStart = append(childStart, 0)
  ci = 0
  while ci < k {
    childStart = append(childStart, childStart[ci] + childCount[ci])
    ci = ci + 1
  }
  let totalChildren = childStart[k]

  // Fill children flat array
  var childrenFlat: list<int> = []
  ci = 0
  while ci < totalChildren { childrenFlat = append(childrenFlat, 0); ci = ci + 1 }
  var pos: list<int> = []
  ci = 0
  while ci < k { pos = append(pos, childStart[ci]); ci = ci + 1 }
  pi = 1
  while pi < k {
    let pIdx = nameToIdx[parentName[pi]] as int
    childrenFlat[pos[pIdx]] = pi
    pos[pIdx] = pos[pIdx] + 1
    pi = pi + 1
  }

  // Compute subtree weights (sum of chat times in subtree)
  // Process in reverse topological order (children appear after parents in input,
  // so process from k-1 down to 0)
  var subtreeW: list<int> = []
  ci = 0
  while ci < k { subtreeW = append(subtreeW, chatTimes[ci]); ci = ci + 1 }
  // Process in reverse order (leaves first)
  var ri = k - 1
  while ri >= 1 {
    let pIdx = nameToIdx[parentName[ri]] as int
    subtreeW[pIdx] = subtreeW[pIdx] + subtreeW[ri]
    ri = ri - 1
  }

  // Sort each node's children by subtree weight ascending (insertion sort)
  var si = 0
  while si < k {
    let start = childStart[si]
    let end = childStart[si + 1]
    // Insertion sort children[start..end] by subtreeW
    var ii = start + 1
    while ii < end {
      let key = childrenFlat[ii]
      let keyW = subtreeW[key]
      var jj = ii - 1
      while jj >= start && subtreeW[childrenFlat[jj]] > keyW {
        childrenFlat[jj + 1] = childrenFlat[jj]
        jj = jj - 1
      }
      childrenFlat[jj + 1] = key
      ii = ii + 1
    }
    si = si + 1
  }

  // Iterative DFS from root to generate output
  // Stack stores: (node_idx, child_iter_position)
  // We simulate: visit node, then for each child, output response and recurse
  //
  // Use two parallel stacks: nodeStack and iterStack
  // iterStack[top] = current child index position for nodeStack[top]
  var nodeStack: list<int> = []
  var iterStack: list<int> = []

  // Start with root
  nodeStack = append(nodeStack, rootIdx)
  iterStack = append(iterStack, childStart[rootIdx])
  print(names[rootIdx])

  var stackSize = 1
  while stackSize > 0 {
    let top = stackSize - 1
    let node = nodeStack[top]
    let iter = iterStack[top]
    let nodeEnd = childStart[node + 1]

    if iter >= nodeEnd {
      // Done with this node's children, pop
      stackSize = stackSize - 1
    } else {
      // Get next child and advance iterator
      let child = childrenFlat[iter]
      iterStack[top] = iter + 1

      // Output response token (child's name) and visit child
      print(names[child])  // response token: she passed to child
      print(names[child])  // now visit child

      // Check if child is a leaf (no children)
      if childStart[child] < childStart[child + 1] {
        // Child has children, push onto stack
        nodeStack = append(nodeStack, child)
        iterStack = append(iterStack, childStart[child])
        stackSize = stackSize + 1
      }
      // If child is a leaf, it's terminal (she has recipe), nothing more to output
    }
  }
}

main()
