// Solution for SPOJ GRIDPNT - Grid points
// https://www.spoj.com/problems/GRIDPNT/
// Given (x1,y1) visible from origin in [0,n]^2 grid, find next point clockwise.
// Generate all visible points (gcd=1), sort by angle CCW ascending,
// then the previous point in this list is the next CW point.

fun gcd(a: int, b: int): int {
  while b > 0 {
    let t = b
    b = a % b
    a = t
  }
  return a
}

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

// Returns 1 if (ax,ay) has strictly smaller angle than (bx,by)
// i.e. cross product ax*by - bx*ay > 0
fun lessAngle(ax: int, ay: int, bx: int, by: int): int {
  let cross = ax * by - bx * ay
  if cross > 0 { return 1 } else { return 0 }
}

fun main() {
  let t = int(input())
  var ti = 0
  while ti < t {
    let p = split(input())
    let n = int(p[0])
    let x1 = int(p[1])
    let y1 = int(p[2])

    // Generate all visible points in [0,n]x[0,n] with gcd=1
    // Store as flat list: px[i], py[i]
    var px: list<int> = []
    var py: list<int> = []

    var x = 0
    while x <= n {
      var y = 0
      while y <= n {
        if (x > 0 || y > 0) && gcd(x, y) == 1 {
          px = append(px, x)
          py = append(py, y)
        }
        y = y + 1
      }
      x = x + 1
    }

    let sz = len(px)

    // Insertion sort by angle CCW ascending
    // (ax,ay) < (bx,by) iff ax*by - bx*ay > 0
    var i = 1
    while i < sz {
      let kx = px[i]
      let ky = py[i]
      var j = i - 1
      while j >= 0 && lessAngle(kx, ky, px[j], py[j]) == 1 {
        px[j+1] = px[j]
        py[j+1] = py[j]
        j = j - 1
      }
      px[j+1] = kx
      py[j+1] = ky
      i = i + 1
    }

    // Find (x1,y1) in sorted list
    var idx = 0
    i = 0
    while i < sz {
      if px[i] == x1 && py[i] == y1 { idx = i }
      i = i + 1
    }

    // Previous element (going CW = decreasing angle)
    var prev = idx - 1
    if prev < 0 { prev = sz - 1 }

    print(str(px[prev]) + " " + str(py[prev]))
    ti = ti + 1
  }
}

main()
