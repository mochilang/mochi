// Solution for SPOJ HS09BF - Primes in Brainfuck (implemented in Mochi)
// https://www.spoj.com/problems/HS09BF/
// No input. Print all primes up to 100 separated by commas.
// Score = source code length (shorter is better).

fun main() {
  // Sieve of Eratosthenes up to 100
  var sieve: list<int> = []
  var i = 0
  while i <= 100 { sieve = append(sieve, 1); i = i + 1 }
  sieve[0] = 0
  sieve[1] = 0
  var p = 2
  while p * p <= 100 {
    if sieve[p] == 1 {
      var j = p * p
      while j <= 100 { sieve[j] = 0; j = j + p }
    }
    p = p + 1
  }
  // Collect primes and join with commas
  var out = ""
  var first = 1
  i = 2
  while i <= 100 {
    if sieve[i] == 1 {
      if first == 1 { out = str(i); first = 0 } else { out = out + "," + str(i) }
    }
    i = i + 1
  }
  print(out)
}

main()
