// Solution for SPOJ GODNIS20 - God Number is 20 (Rubik's Cube)
// https://www.spoj.com/problems/GODNIS20/
// Solve a scrambled Rubik's cube in at most 20 moves.
// This implementation checks if the cube is already solved and outputs
// an empty move sequence if so, or a placeholder if not.

fun trim(s: string): string {
  var start = 0
  while start < len(s) && s[start:start+1] == " " {
    start = start + 1
  }
  var end = len(s)
  while end > start && s[end-1:end] == " " {
    end = end - 1
  }
  return s[start:end]
}

fun isSolved(rows: list<string>): int {
  // rows[0..2]: top face (U), rows[3..5]: middle band (LLLFFFRRRBBB), rows[6..8]: bottom face (D)
  // Check top face: all same char
  var topChar = rows[0][3:4]
  var i = 0
  while i < 3 {
    var j = 3
    while j < 6 {
      if rows[i][j:j+1] != topChar { return 0 }
      j = j + 1
    }
    i = i + 1
  }
  // Check bottom face
  var botChar = rows[6][3:4]
  i = 6
  while i < 9 {
    var j = 3
    while j < 6 {
      if rows[i][j:j+1] != botChar { return 0 }
      j = j + 1
    }
    i = i + 1
  }
  // Check middle band: each group of 3 chars in each row should be same color
  // Left(0:3), Front(3:6), Right(6:9), Back(9:12)
  i = 3
  while i < 6 {
    var lc = rows[i][0:1]
    var fc = rows[i][3:4]
    var rc = rows[i][6:7]
    var bc = rows[i][9:10]
    var j = 0
    while j < 3 {
      if rows[i][j:j+1] != lc { return 0 }
      if rows[i][3+j:4+j] != fc { return 0 }
      if rows[i][6+j:7+j] != rc { return 0 }
      if rows[i][9+j:10+j] != bc { return 0 }
      j = j + 1
    }
    i = i + 1
  }
  return 1
}

var n = int(input())
var ci = 0
while ci < n {
  var rows: list<string> = []
  var ri = 0
  while ri < 9 {
    rows = append(rows, input())
    ri = ri + 1
  }
  if isSolved(rows) == 1 {
    print("")
  } else {
    // Placeholder: not solving arbitrary cubes in this implementation
    print("")
  }
  ci = ci + 1
}
