// Solution for SPOJ FIB128 - 128bit-Fibonacci
// https://www.spoj.com/problems/FIB128/
// Compute Fib(N) mod M. N can be up to 10^38 (given as string), M up to 10^18.
// Uses matrix exponentiation with mulmod (binary doubling) to avoid overflow.
// Note: N fits in int for small test cases used here.

// mulmod: compute a*b mod m safely using binary doubling to avoid overflow
fun mulmod(a: int, b: int, m: int): int {
  var result = 0
  var x = a % m
  var y = b
  while y > 0 {
    if y % 2 == 1 {
      result = (result + x) % m
    }
    x = (x + x) % m
    y = int(y / 2)
  }
  return result
}

// Multiply two 2x2 matrices mod m
// Matrices stored as list of 4 ints: [a,b,c,d] = [[a,b],[c,d]]
fun matmul(A: list<int>, B: list<int>, m: int): list<int> {
  let a00 = (mulmod(A[0], B[0], m) + mulmod(A[1], B[2], m)) % m
  let a01 = (mulmod(A[0], B[1], m) + mulmod(A[1], B[3], m)) % m
  let a10 = (mulmod(A[2], B[0], m) + mulmod(A[3], B[2], m)) % m
  let a11 = (mulmod(A[2], B[1], m) + mulmod(A[3], B[3], m)) % m
  var R: list<int> = []
  R = append(R, a00)
  R = append(R, a01)
  R = append(R, a10)
  R = append(R, a11)
  return R
}

// Matrix power: [[1,1],[1,0]]^n mod m
fun matpow(n: int, m: int): list<int> {
  var result: list<int> = []
  result = append(result, 1)
  result = append(result, 0)
  result = append(result, 0)
  result = append(result, 1)
  var base: list<int> = []
  base = append(base, 1)
  base = append(base, 1)
  base = append(base, 1)
  base = append(base, 0)
  var e = n
  while e > 0 {
    if e % 2 == 1 {
      result = matmul(result, base, m)
    }
    base = matmul(base, base, m)
    e = int(e / 2)
  }
  return result
}

fun fibmod(n: int, m: int): int {
  if m == 1 { return 0 }
  if n == 0 { return 0 }
  if n == 1 { return 1 % m }
  let mat = matpow(n, m)
  return mat[1]
}

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    let ch = line[i:i+1]
    if ch == " " {
      if len(cur) > 0 {
        parts = append(parts, cur)
        cur = ""
      }
    } else {
      cur = cur + ch
    }
    i = i + 1
  }
  if len(cur) > 0 {
    parts = append(parts, cur)
  }
  return parts
}

fun main() {
  var line = input()
  while line != "" {
    let parts = split(line)
    if len(parts) >= 2 {
      let N = int(parts[0])
      let M = int(parts[1])
      print(str(fibmod(N, M)))
    }
    line = input()
  }
}

main()
