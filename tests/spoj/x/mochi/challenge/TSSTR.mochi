// Solution for SPOJ TSSTR - Shortest Superstring
// https://www.spoj.com/problems/TSSTR/
// Find the shortest superstring containing all input words as substrings.
// Greedy: repeatedly merge the pair with highest overlap until one string remains.
// Then find each original word's position in the result.

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

// Compute overlap: length of longest suffix of a that equals prefix of b
fun overlap(a: string, b: string): int {
  let la = len(a)
  let lb = len(b)
  var maxOv = la
  if lb < maxOv { maxOv = lb }
  var best = 0
  var k = 1
  while k <= maxOv {
    if a[la - k : la] == b[0 : k] {
      best = k
    }
    k = k + 1
  }
  return best
}

// Find first occurrence of pattern in text; return -1 if not found
fun findStr(text: string, pat: string): int {
  let nt = len(text)
  let np = len(pat)
  if np == 0 { return 0 }
  if np > nt { return 0 - 1 }
  var i = 0
  while i <= nt - np {
    if text[i : i + np] == pat {
      return i
    }
    i = i + 1
  }
  return 0 - 1
}

fun main() {
  var tLine = input()
  let T = int(tLine)
  var tc = 1
  while tc <= T {
    let nLine = input()
    let n = int(nLine)

    var words: list<string> = []
    var i = 0
    while i < n {
      words = append(words, input())
      i = i + 1
    }

    // Save original words for position lookup
    var origWords: list<string> = []
    i = 0
    while i < n {
      origWords = append(origWords, words[i])
      i = i + 1
    }

    // Work with mutable list of current strings (will reduce to 1)
    var cur: list<string> = []
    i = 0
    while i < n { cur = append(cur, words[i]); i = i + 1 }

    // Remove words that are substrings of other words
    var dominated: list<int> = []
    i = 0
    while i < len(cur) { dominated = append(dominated, 0); i = i + 1 }

    i = 0
    while i < len(cur) {
      var j = 0
      while j < len(cur) {
        if i != j && dominated[i] == 0 && dominated[j] == 0 {
          if len(cur[i]) <= len(cur[j]) {
            if findStr(cur[j], cur[i]) != 0 - 1 {
              // cur[i] is substring of cur[j]: only dominate if strictly shorter
              if len(cur[i]) < len(cur[j]) {
                dominated[i] = 1
              }
            }
          }
        }
        j = j + 1
      }
      i = i + 1
    }

    var active: list<string> = []
    i = 0
    while i < len(cur) {
      if dominated[i] == 0 {
        active = append(active, cur[i])
      }
      i = i + 1
    }

    // Greedy merge: find pair with maximum overlap and merge them
    var sz = len(active)
    while sz > 1 {
      var bestOv = 0 - 1
      var bestI = 0
      var bestJ = 1
      i = 0
      while i < sz {
        var j = 0
        while j < sz {
          if i != j {
            let ov = overlap(active[i], active[j])
            if ov > bestOv {
              bestOv = ov
              bestI = i
              bestJ = j
            }
          }
          j = j + 1
        }
        i = i + 1
      }
      // Merge active[bestI] + active[bestJ] with overlap bestOv
      let merged = active[bestI] + active[bestJ][bestOv : len(active[bestJ])]
      var next: list<string> = []
      i = 0
      while i < sz {
        if i != bestI && i != bestJ {
          next = append(next, active[i])
        }
        i = i + 1
      }
      next = append(next, merged)
      active = next
      sz = len(active)
    }

    let superstr = active[0]

    // Output
    print("case " + string(tc) + " Y")
    print(superstr)
    i = 0
    while i < n {
      let pos = findStr(superstr, origWords[i])
      print(pos + 1)
      i = i + 1
    }

    tc = tc + 1
  }
}

main()
