// Solution for SPOJ EQCHECK - Equation Check
// https://www.spoj.com/problems/EQCHECK/
// Ax+By=C passes through a lattice point iff gcd(A,B) divides C.

fun gcd(a: int, b: int): int {
  while b > 0 {
    let t = b
    b = a % b
    a = t
  }
  return a
}

fun main() {
  let t = int(input())
  var ti = 0
  while ti < t {
    let line = input()
    // Parse: scan for 'x' to get A, then for 'y' to get B, then after '=' get C
    var i = 0
    // Read A (digits before 'x')
    var aStr = ""
    while i < len(line) && line[i:i+1] != "x" {
      aStr = aStr + line[i:i+1]
      i = i + 1
    }
    i = i + 1  // skip 'x'
    // Skip '+'
    if i < len(line) && line[i:i+1] == "+" { i = i + 1 }
    // Read B (digits before 'y')
    var bStr = ""
    while i < len(line) && line[i:i+1] != "y" {
      bStr = bStr + line[i:i+1]
      i = i + 1
    }
    i = i + 1  // skip 'y'
    // Skip '='
    if i < len(line) && line[i:i+1] == "=" { i = i + 1 }
    // Read C
    var cStr = ""
    while i < len(line) {
      cStr = cStr + line[i:i+1]
      i = i + 1
    }
    let a = int(aStr)
    let b = int(bStr)
    let c = int(cStr)
    let g = gcd(a, b)
    if c % g == 0 {
      print("yes")
    } else {
      print("no")
    }
    ti = ti + 1
  }
}

main()
