// Solution for SPOJ BFBIGTHN - "If Bigger Than" in BF
// https://www.spoj.com/problems/BFBIGTHN/
// Read t, then t lines "aa bb". Output 1 if a > b, else 0.

fun split(s: string): list<string> {
  var r: list<string> = []
  var c = ""
  var i = 0
  while i < len(s) {
    if s[i:i+1] == " " {
      if len(c) > 0 { r = append(r, c); c = "" }
    } else { c = c + s[i:i+1] }
    i = i + 1
  }
  if len(c) > 0 { r = append(r, c) }
  return r
}

fun main() {
  let t = int(input())
  var i = 0
  while i < t {
    let p = split(input())
    let a = int(p[0])
    let b = int(p[1])
    var r = 0
    if a > b { r = 1 }
    print(r)
    i = i + 1
  }
}

main()
