// Solution for SPOJ MATRMUL - Matrix Multiplication 4K
// https://www.spoj.com/problems/MATRMUL/
// Generate matrices A, B via LCG, compute C=A*B, output XOR of each row of C.

// XOR two non-negative integers using bit-by-bit simulation
fun xorInts(a: int, b: int): int {
  var result = 0
  var bit = 1
  var ai = a
  var bi = b
  var iter = 0
  while iter < 63 {
    let aBit = ai % 2
    let bBit = bi % 2
    if aBit != bBit {
      result = result + bit
    }
    ai = int(ai / 2)
    bi = int(bi / 2)
    bit = bit * 2
    iter = iter + 1
  }
  return result
}

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun main() {
  let MOD32 = 4294967296
  let line = input()
  let p = split(line)
  let n = int(p[0])
  let p1 = int(p[1])
  var d1 = int(p[2])
  let r1 = int(p[3])
  let m1 = int(p[4])
  let p2 = int(p[5])
  var d2 = int(p[6])
  let r2 = int(p[7])
  let m2 = int(p[8])

  // Compute shift divisors: A[i][j] = d1 >> (32-m1) = int(d1 / 2^(32-m1))
  // shift1 = 2^(32-m1), shift2 = 2^(32-m2)
  var shift1 = 1
  var si = 0
  while si < 32 - m1 { shift1 = shift1 * 2; si = si + 1 }
  var shift2 = 1
  var sj = 0
  while sj < 32 - m2 { shift2 = shift2 * 2; sj = sj + 1 }

  // Generate A and B as flat lists (n*n elements)
  var A: list<int> = []
  var B: list<int> = []
  var row = 0
  while row < n {
    var col = 0
    while col < n {
      d1 = (d1 * p1 + r1) % MOD32
      d2 = (d2 * p2 + r2) % MOD32
      A = append(A, int(d1 / shift1))
      B = append(B, int(d2 / shift2))
      col = col + 1
    }
    row = row + 1
  }

  // Compute V[i] = XOR over j of C[i][j] = XOR over j of (sum_k A[i][k]*B[k][j])
  // For each row i: compute C[i][j] for each j and XOR into V[i]
  var V: list<int> = []
  var ri = 0
  while ri < n { V = append(V, 0); ri = ri + 1 }

  var i = 0
  while i < n {
    var j = 0
    while j < n {
      // Compute C[i][j] = sum_k A[i][k] * B[k][j]
      var cij = 0
      var k = 0
      while k < n {
        cij = cij + A[i * n + k] * B[k * n + j]
        k = k + 1
      }
      V[i] = xorInts(V[i], cij)
      j = j + 1
    }
    i = i + 1
  }

  // Output V[0] V[1] ... V[n-1] separated by spaces
  var out = ""
  var oi = 0
  while oi < n {
    if oi > 0 { out = out + " " }
    out = out + str(V[oi])
    oi = oi + 1
  }
  print(out)
}

main()
