// Solution for SPOJ JCROSS - Japan Crossword
// https://www.spoj.com/problems/JCROSS/
// Nonogram solver using iterative constraint propagation.
// For each line, enumerate all valid block placements (compatible with current known cells),
// then mark cells as '#' if filled in all placements, '.' if empty in all placements.
// Repeat until stable.

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun parseHints(line: string): list<int> {
  let parts = split(line)
  var hints: list<int> = []
  var i = 0
  while i < len(parts) {
    let v = int(parts[i])
    if v == 0 { i = len(parts) } else {
      hints = append(hints, v)
      i = i + 1
    }
  }
  return hints
}

// Sum of a sublist hints[from..to)
fun sumHints(hints: list<int>, from: int, to: int): int {
  var s = 0
  var i = from
  while i < to { s = s + hints[i]; i = i + 1 }
  return s
}

// Enumerate all valid placements for hints in cells[0..width).
// cells: 0=unknown, 1=filled, -1=empty
// A placement is a flat list of block starts: [s0, s1, s2, ...]
// We use an iterative stack-based approach.
// Returns flat list of all placements concatenated, with a count.
// To avoid complex nested lists, we store placements in a flat list
// and track count separately.
//
// For efficiency, store ALL placements as a flat int list:
// [num_placements, k, s0_of_p0, s1_of_p0, ..., s0_of_p1, s1_of_p1, ...]
// where k = number of blocks.
//
// Then compute allFilled and allEmpty by scanning all placements.

fun solveLine(cells: list<int>, hints: list<int>, width: int): list<int> {
  let k = len(hints)

  // No hints: all cells must be empty
  if k == 0 {
    var res: list<int> = []
    var i = 0
    while i < width {
      if cells[i] == 1 { res = append(res, cells[i]) } else { res = append(res, 0 - 1) }
      i = i + 1
    }
    return res
  }

  // Compute min space needed
  var minSpace = sumHints(hints, 0, k) + k - 1
  if minSpace > width { return cells }

  // allFilled[i] = 1 means every valid placement fills cell i
  // allEmpty[i] = 1 means every valid placement leaves cell i empty
  var allFilled: list<int> = []
  var allEmpty: list<int> = []
  var i = 0
  while i < width { allFilled = append(allFilled, 1); allEmpty = append(allEmpty, 1); i = i + 1 }

  var foundAny = 0

  // Iterative backtracking to enumerate placements
  // State: for each block index 0..k-1, the start position
  // Use arrays: stk_pos[bi] = current start for block bi
  //             stk_min[bi] = minimum start for block bi
  var stk_pos: list<int> = []
  var stk_min: list<int> = []
  i = 0
  while i < k { stk_pos = append(stk_pos, 0); stk_min = append(stk_min, 0); i = i + 1 }

  // Compute minimum start for each block
  var ms = 0
  i = 0
  while i < k {
    stk_min[i] = ms
    stk_pos[i] = ms
    ms = ms + hints[i] + 1
    i = i + 1
  }

  // Compute maximum start for each block
  var stk_max: list<int> = []
  i = 0
  while i < k { stk_max = append(stk_max, 0); i = i + 1 }
  var mx = width - hints[k - 1]
  i = k - 1
  while i >= 0 {
    stk_max[i] = mx
    if i > 0 { mx = mx - hints[i - 1] - 1 }
    i = i - 1
  }

  var bi = 0  // current block index
  // Reset positions to minimums
  i = 0
  while i < k { stk_pos[i] = stk_min[i]; i = i + 1 }

  var done = 0
  while done == 0 {
    // At block bi, try to place at stk_pos[bi]
    let b = hints[bi]
    let s = stk_pos[bi]

    // Check if placement at s is valid: no -1 in [s, s+b)
    var valid = 1
    if s + b > width { valid = 0 } else {
      var p = s
      while p < s + b {
        if cells[p] == 0 - 1 { valid = 0; p = s + b } else { p = p + 1 }
      }
    }

    if valid == 1 {
      // Also check: no '#' in the gap before this block from previous block end
      if bi > 0 {
        let prevEnd = stk_pos[bi - 1] + hints[bi - 1]
        var p2 = prevEnd
        while p2 < s {
          if cells[p2] == 1 { valid = 0; p2 = s } else { p2 = p2 + 1 }
        }
      } else {
        // Check no '#' before s
        var p2 = 0
        while p2 < s {
          if cells[p2] == 1 { valid = 0; p2 = s } else { p2 = p2 + 1 }
        }
      }
    }

    if valid == 1 && bi == k - 1 {
      // Check no '#' after last block
      let lastEnd = s + b
      var p2 = lastEnd
      while p2 < width {
        if cells[p2] == 1 { valid = 0; p2 = width } else { p2 = p2 + 1 }
      }
    }

    if valid == 1 && bi < k - 1 {
      // Go deeper
      bi = bi + 1
      stk_pos[bi] = stk_pos[bi - 1] + hints[bi - 1] + 1
      // Ensure min
      if stk_pos[bi] < stk_min[bi] { stk_pos[bi] = stk_min[bi] }
    } else if valid == 1 && bi == k - 1 {
      // Found a complete placement — update allFilled/allEmpty
      foundAny = 1

      // Build this placement's coverage
      var cover: list<int> = []
      var p = 0
      while p < width { cover = append(cover, 0); p = p + 1 }
      var bj = 0
      while bj < k {
        p = stk_pos[bj]
        while p < stk_pos[bj] + hints[bj] {
          cover[p] = 1
          p = p + 1
        }
        bj = bj + 1
      }

      // Update allFilled and allEmpty
      p = 0
      while p < width {
        if cover[p] == 0 { allFilled[p] = 0 }
        if cover[p] == 1 { allEmpty[p] = 0 }
        p = p + 1
      }

      // Advance: try next position for block bi
      stk_pos[bi] = stk_pos[bi] + 1
    } else {
      // Invalid or exhausted: advance current block
      stk_pos[bi] = stk_pos[bi] + 1
    }

    // If current block position exceeds max, backtrack
    while bi >= 0 && stk_pos[bi] > stk_max[bi] {
      if bi == 0 {
        done = 1
        bi = 0 - 1
      } else {
        bi = bi - 1
        stk_pos[bi] = stk_pos[bi] + 1
      }
    }
    if bi < 0 { done = 1 }
  }

  if foundAny == 0 { return cells }

  // Apply deductions
  var res: list<int> = []
  i = 0
  while i < width {
    if cells[i] != 0 {
      res = append(res, cells[i])
    } else if allFilled[i] == 1 {
      res = append(res, 1)
    } else if allEmpty[i] == 1 {
      res = append(res, 0 - 1)
    } else {
      res = append(res, 0)
    }
    i = i + 1
  }
  return res
}

fun main() {
  let tLine = input()
  if tLine == "" { return }
  let T = int(tLine)
  var tc = 0
  while tc < T {
    let rcLine = input()
    let rc = split(rcLine)
    let R = int(rc[0])
    let C = int(rc[1])

    var rowHints: list<list<int>> = []
    var r = 0
    while r < R { rowHints = append(rowHints, parseHints(input())); r = r + 1 }

    var colHints: list<list<int>> = []
    var c = 0
    while c < C { colHints = append(colHints, parseHints(input())); c = c + 1 }

    // Initialize grid: 0=unknown
    var grid: list<int> = []
    var i = 0
    while i < R * C { grid = append(grid, 0); i = i + 1 }

    // Iterative constraint propagation
    var changed = 1
    while changed == 1 {
      changed = 0

      r = 0
      while r < R {
        var rowCells: list<int> = []
        c = 0
        while c < C { rowCells = append(rowCells, grid[r * C + c]); c = c + 1 }
        let newRow = solveLine(rowCells, rowHints[r], C)
        c = 0
        while c < C {
          if newRow[c] != grid[r * C + c] { grid[r * C + c] = newRow[c]; changed = 1 }
          c = c + 1
        }
        r = r + 1
      }

      c = 0
      while c < C {
        var colCells: list<int> = []
        r = 0
        while r < R { colCells = append(colCells, grid[r * C + c]); r = r + 1 }
        let newCol = solveLine(colCells, colHints[c], R)
        r = 0
        while r < R {
          if newCol[r] != grid[r * C + c] { grid[r * C + c] = newCol[r]; changed = 1 }
          r = r + 1
        }
        c = c + 1
      }
    }

    // Output
    r = 0
    while r < R {
      var rowStr = ""
      c = 0
      while c < C {
        if grid[r * C + c] == 1 { rowStr = rowStr + "#" } else { rowStr = rowStr + "." }
        c = c + 1
      }
      print(rowStr)
      r = r + 1
    }

    tc = tc + 1
  }
}

main()
