// Solution for SPOJ MPPZF - Piggy Bank
// https://www.spoj.com/problems/MPPZF/
// Simulate a piggy bank with coin exchange events.
// Coins: denomination <= 10000. Banknotes: > 10000.
// On 'w': find min coin denom. If count >= 2, exchange all for count*denom (coin or banknote).
//         If count = 1, also take next-min coin, exchange for sum of both.
// On 'k': print max banknote value, or "bb" if none.

fun split(s: string): list<string> {
  var r: list<string> = []
  var c = ""
  var i = 0
  while i < len(s) {
    if s[i:i+1] == " " {
      if len(c) > 0 { r = append(r, c); c = "" }
    } else { c = c + s[i:i+1] }
    i = i + 1
  }
  if len(c) > 0 { r = append(r, c) }
  return r
}

// Find minimum non-zero index in coins array (1..10000)
fun findMin(coins: list<int>): int {
  var i = 1
  while i <= 10000 {
    if coins[i] > 0 { return i }
    i = i + 1
  }
  return 0 - 1
}

// Find second minimum (first non-zero after minD)
fun findNextMin(coins: list<int>, minD: int): int {
  var i = minD + 1
  while i <= 10000 {
    if coins[i] > 0 { return i }
    i = i + 1
  }
  return 0 - 1
}

fun main() {
  let nLine = input()
  if nLine == "" { return }
  let T = int(nLine)
  var ti = 0
  while ti < T {
    // coins[d] = count of coin denomination d (1..10000)
    var coins: list<int> = []
    var ci = 0
    while ci <= 10001 { coins = append(coins, 0); ci = ci + 1 }
    var maxBanknote = 0
    var hasK = 0
    var answers: list<string> = []

    var running = 1
    while running == 1 {
      let line = input()
      if line == "" { running = 0 }
      else {
        let tokens = split(line)
        var ti2 = 0
        while ti2 < len(tokens) {
          let tok = tokens[ti2]
          if tok == "0" {
            running = 0
            ti2 = len(tokens)
          } else {
            if tok == "w" {
              // Exchange event
              let minD = findMin(coins)
              if minD > 0 {
                let cnt = coins[minD]
                var newVal = 0
                if cnt >= 2 {
                  coins[minD] = 0
                  newVal = cnt * minD
                } else {
                  // cnt == 1: take minD and nextMin
                  let nextD = findNextMin(coins, minD)
                  coins[minD] = 0
                  if nextD > 0 {
                    coins[nextD] = coins[nextD] - 1
                    newVal = minD + nextD
                  } else {
                    // Only one coin total, no next - just remove it, no exchange
                    newVal = 0
                  }
                }
                if newVal > 0 {
                  if newVal <= 10000 {
                    coins[newVal] = coins[newVal] + 1
                  } else {
                    if newVal > maxBanknote { maxBanknote = newVal }
                  }
                }
              }
            } else {
              if tok == "k" {
                hasK = 1
                if maxBanknote > 0 {
                  answers = append(answers, str(maxBanknote))
                } else {
                  answers = append(answers, "bb")
                }
              } else {
                // It's a coin denomination
                let d = int(tok)
                if d <= 10000 {
                  coins[d] = coins[d] + 1
                }
                // Ignore denominations > 10000 (problem says coins go up to 10000)
              }
            }
            ti2 = ti2 + 1
          }
        }
      }
    }

    if hasK == 1 {
      var out = ""
      var ai = 0
      while ai < len(answers) {
        if ai > 0 { out = out + " " }
        out = out + answers[ai]
        ai = ai + 1
      }
      print(out)
    }

    ti = ti + 1
  }
}

main()
