// Solution for SPOJ PRINTF - Printf Parser
// https://www.spoj.com/problems/PRINTF/
// Parse C printf statements and print their output.
// Format specifiers: %d (int), %c (char), %f (float 6dp), %s (string).
// Score = source code length (shorter is better).

// Format a float string to exactly 6 decimal places (truncate, no rounding).
fun formatFloat(s: string): string {
  var dot = 0 - 1
  var i = 0
  while i < len(s) {
    if s[i:i+1] == "." { dot = i }
    i = i + 1
  }
  var intPart = s
  var fracPart = ""
  if dot >= 0 {
    intPart = s[0:dot]
    fracPart = s[dot+1:len(s)]
  }
  // Pad fracPart to at least 6 chars
  while len(fracPart) < 6 { fracPart = fracPart + "0" }
  // Truncate to exactly 6
  return intPart + "." + fracPart[0:6]
}

// Split args string on commas (top-level only, respecting quoted strings).
fun splitArgs(s: string): list<string> {
  var args: list<string> = []
  var cur = ""
  var inStr = 0
  var inChar = 0
  var i = 0
  while i < len(s) {
    let ch = s[i:i+1]
    if inStr == 1 {
      if ch == "\"" { inStr = 0 }
      cur = cur + ch
    } else {
      if inChar == 1 {
        if ch == "'" { inChar = 0 }
        cur = cur + ch
      } else {
        if ch == "\"" { inStr = 1; cur = cur + ch } else {
          if ch == "'" { inChar = 1; cur = cur + ch } else {
            if ch == "," {
              // trim spaces from cur
              var trimmed = ""
              var j = 0
              while j < len(cur) {
                if cur[j:j+1] != " " { trimmed = trimmed + cur[j:j+1] }
                j = j + 1
              }
              args = append(args, trimmed)
              cur = ""
            } else {
              cur = cur + ch
            }
          }
        }
      }
    }
    i = i + 1
  }
  // last arg
  var trimmed = ""
  var j = 0
  while j < len(cur) {
    if cur[j:j+1] != " " { trimmed = trimmed + cur[j:j+1] }
    j = j + 1
  }
  if len(trimmed) > 0 { args = append(args, trimmed) }
  return args
}

// Get string value of an arg token.
// '%c' arg: 'X' -> "X"
// '%s' arg: "foo" -> "foo"
// '%d' arg: 123 -> "123"
// '%f' arg: 4.5 -> "4.500000"
fun argVal(tok: string, spec: string): string {
  if spec == "%c" {
    // tok like 'L' -> return L
    return tok[1:2]
  }
  if spec == "%s" {
    // tok like "problem" -> return content between quotes
    return tok[1:len(tok)-1]
  }
  if spec == "%f" {
    return formatFloat(tok)
  }
  // %d
  return tok
}

fun parsePrintf(line: string) {
  // Find content inside printf(...)
  // Find first '(' and last ')'
  var parenStart = 0 - 1
  var i = 0
  while i < len(line) {
    if line[i:i+1] == "(" && parenStart < 0 { parenStart = i }
    i = i + 1
  }
  // last ')' - scan backwards
  var parenEnd = 0 - 1
  i = len(line) - 1
  while i >= 0 {
    if line[i:i+1] == ")" && parenEnd < 0 { parenEnd = i }
    i = i - 1
  }
  let content = line[parenStart+1:parenEnd]
  // Find format string: between first " and next "
  var fmtStart = 0 - 1
  var fmtEnd = 0 - 1
  i = 0
  while i < len(content) {
    if content[i:i+1] == "\"" {
      if fmtStart < 0 { fmtStart = i } else {
        if fmtEnd < 0 { fmtEnd = i }
      }
    }
    i = i + 1
  }
  let fmt = content[fmtStart+1:fmtEnd]
  // Args string: everything after the closing quote of format string + ","
  var argsStr = ""
  if fmtEnd + 2 <= len(content) {
    argsStr = content[fmtEnd+2:len(content)]
  }
  let args = splitArgs(argsStr)

  // Process format string
  var out = ""
  var argIdx = 0
  i = 0
  while i < len(fmt) {
    let ch = fmt[i:i+1]
    if ch == "%" {
      let spec = fmt[i:i+2]
      if argIdx < len(args) {
        out = out + argVal(args[argIdx], spec)
        argIdx = argIdx + 1
      }
      i = i + 2
    } else {
      out = out + ch
      i = i + 1
    }
  }
  print(out)
}

fun main() {
  let t = int(input())
  var i = 0
  while i < t {
    parsePrintf(input())
    i = i + 1
  }
}

main()
