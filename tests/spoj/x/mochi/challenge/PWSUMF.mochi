// Solution for SPOJ PWSUMF - Fibonacci Power Sum
// https://www.spoj.com/problems/PWSUMF/
// kth line: given N, output sum(Fib(i)^k for i=1..N) mod 10^9+7.
// k=1: Fib(N+2) - 1 (mod P)
// k=2: Fib(N) * Fib(N+1) (mod P)
// k>=3: brute force (TLE for large N but gives partial credit)

// Fast doubling: returns [Fib(n) mod P, Fib(n+1) mod P]
// F(2n)   = F(n) * (2*F(n+1) - F(n))
// F(2n+1) = F(n)^2 + F(n+1)^2
fun fast_fib(n: int, P: int): list<int> {
  if n == 0 {
    var r: list<int> = []
    r = append(r, 0)
    r = append(r, 1)
    return r
  }
  let half = fast_fib(int(n / 2), P)
  let a = half[0]
  let b = half[1]
  let c = a % P * ((2 * b % P - a % P + P) % P) % P
  let d = (a % P * (a % P) % P + b % P * (b % P) % P) % P
  var res: list<int> = []
  if n % 2 == 0 {
    res = append(res, c)
    res = append(res, d)
  } else {
    res = append(res, d)
    res = append(res, (c + d) % P)
  }
  return res
}

fun modpow(base: int, exp: int, P: int): int {
  var result = 1
  var b = base % P
  var e = exp
  while e > 0 {
    if e % 2 == 1 { result = result * b % P }
    b = b * b % P
    e = int(e / 2)
  }
  return result
}

fun main() {
  let P = 1000000007
  var k = 0
  var line = input()
  while line != "" {
    k = k + 1
    let N = int(line)

    if k == 1 {
      // sum(Fib(i) for i=1..N) = Fib(N+2) - 1
      let fib = fast_fib(N + 2, P)
      let ans = (fib[0] - 1 + P) % P
      print(str(ans))
    } else {
      if k == 2 {
        // sum(Fib(i)^2 for i=1..N) = Fib(N) * Fib(N+1)
        let fib = fast_fib(N, P)
        let ans = fib[0] * fib[1] % P
        print(str(ans))
      } else {
        // k >= 3: brute force
        var f0 = 0
        var f1 = 1
        var s = 0
        var i = 1
        while i <= N {
          s = (s + modpow(f1, k, P)) % P
          let f2 = (f0 + f1) % P
          f0 = f1
          f1 = f2
          i = i + 1
        }
        print(str(s))
      }
    }

    line = input()
  }
}

main()
