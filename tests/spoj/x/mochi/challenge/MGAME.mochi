// Solution for SPOJ MGAME - Multiplayer Game
// https://www.spoj.com/problems/MGAME/
// n players, each with a shoot-list. Each second each living player shoots one enemy.
// Maximize tmax/tmin - 1 where tmax=longest game, tmin=shortest game.
//
// Short game: each round every player shoots the lowest-numbered alive player on their list.
// Players that get shot by anyone die. Repeat until one or zero survive.
//
// Long game: each round arrange shots so exactly one player dies (minimize eliminations).
// Greedy: build a bipartite matching where each player shoots a unique target — the number
// of deaths = number of players targeted (each targeted player dies). To minimize deaths,
// maximize the number of "wasted" shots (multiple shooters on same target → only 1 death).
// Greedy: sort players' target lists; use counting to find a target hit by the most players.
// Have all those players shoot that one target → 1 death. Remaining players shoot freely.
//
// For output: per round, list who each surviving player shoots (space-separated, in player order).

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

// Find first alive target for player p in their list
fun firstAliveTarget(enemies: list<int>, eStart: list<int>, eCount: list<int>, alive: list<int>, p: int): int {
  let start = eStart[p]
  let cnt = eCount[p]
  var j = 0
  while j < cnt {
    let t = enemies[start + j]
    if alive[t] == 1 { return t }
    j = j + 1
  }
  return 0 - 1
}

fun main() {
  var tLine = input()
  while tLine == "" { tLine = input() }
  let T = int(tLine)
  var tc = 1
  while tc <= T {
    var nLine = input()
    while nLine == "" { nLine = input() }
    let n = int(nLine)

    // Read enemy lists (1-indexed players, convert to 0-indexed internally)
    var eStart: list<int> = []
    var eCount: list<int> = []
    var enemies: list<int> = []
    var i = 0
    while i < n {
      var eLine = input()
      while eLine == "" { eLine = input() }
      let ep = split(eLine)
      let cnt = int(ep[0])
      eStart = append(eStart, len(enemies))
      eCount = append(eCount, cnt)
      var j = 0
      while j < cnt {
        enemies = append(enemies, int(ep[j+1]) - 1)
        j = j + 1
      }
      i = i + 1
    }

    // ---- SHORT GAME ----
    // Each player shoots first alive enemy on their list; all targeted players die.
    var aliveS: list<int> = []
    i = 0
    while i < n { aliveS = append(aliveS, 1); i = i + 1 }

    var shortRounds: list<string> = []
    var shortAlive = n
    while shortAlive > 1 {
      // Determine shots
      var shots: list<int> = []
      i = 0
      while i < n { shots = append(shots, 0 - 1); i = i + 1 }

      // Mark targeted
      var targeted: list<int> = []
      i = 0
      while i < n { targeted = append(targeted, 0); i = i + 1 }

      i = 0
      while i < n {
        if aliveS[i] == 1 {
          let t = firstAliveTarget(enemies, eStart, eCount, aliveS, i)
          shots[i] = t
          if t != 0 - 1 { targeted[t] = 1 }
        }
        i = i + 1
      }

      // Build output line: alive players in order, their shots (1-indexed)
      var line = ""
      var first = 1
      i = 0
      while i < n {
        if aliveS[i] == 1 {
          if first == 0 { line = line + " " }
          if shots[i] == 0 - 1 {
            line = line + "0"
          } else {
            line = line + string(shots[i] + 1)
          }
          first = 0
        }
        i = i + 1
      }
      shortRounds = append(shortRounds, line)

      // Kill targeted players
      i = 0
      while i < n {
        if aliveS[i] == 1 && targeted[i] == 1 {
          aliveS[i] = 0
          shortAlive = shortAlive - 1
        }
        i = i + 1
      }
    }

    // ---- LONG GAME ----
    // Each round: find target hit by most alive players; everyone shoots that one.
    // This means exactly 1 player dies per round (unless no one has a valid target).
    var aliveL: list<int> = []
    i = 0
    while i < n { aliveL = append(aliveL, 1); i = i + 1 }

    var longRounds: list<string> = []
    var longAlive = n
    while longAlive > 1 {
      // Count how many alive players can shoot each alive target
      var hitCount: list<int> = []
      i = 0
      while i < n { hitCount = append(hitCount, 0); i = i + 1 }

      i = 0
      while i < n {
        if aliveL[i] == 1 {
          let t = firstAliveTarget(enemies, eStart, eCount, aliveL, i)
          if t != 0 - 1 { hitCount[t] = hitCount[t] + 1 }
        }
        i = i + 1
      }

      // Find target with maximum hits (most wasted shots → only 1 death)
      var bestTarget = 0 - 1
      var bestCount = 0
      i = 0
      while i < n {
        if aliveL[i] == 1 && hitCount[i] > bestCount {
          bestCount = hitCount[i]
          bestTarget = i
        }
        i = i + 1
      }

      // Assign shots: players who can shoot bestTarget do so; others shoot their first alive enemy
      var shotsL: list<int> = []
      i = 0
      while i < n { shotsL = append(shotsL, 0 - 1); i = i + 1 }

      var targeted2: list<int> = []
      i = 0
      while i < n { targeted2 = append(targeted2, 0); i = i + 1 }

      i = 0
      while i < n {
        if aliveL[i] == 1 {
          let t = firstAliveTarget(enemies, eStart, eCount, aliveL, i)
          if t == bestTarget {
            shotsL[i] = bestTarget
            targeted2[bestTarget] = 1
          } else if t != 0 - 1 {
            shotsL[i] = t
            targeted2[t] = 1
          }
        }
        i = i + 1
      }

      // Build output line
      var line = ""
      var first = 1
      i = 0
      while i < n {
        if aliveL[i] == 1 {
          if first == 0 { line = line + " " }
          if shotsL[i] == 0 - 1 {
            line = line + "0"
          } else {
            line = line + string(shotsL[i] + 1)
          }
          first = 0
        }
        i = i + 1
      }
      longRounds = append(longRounds, line)

      // Kill targeted players
      i = 0
      while i < n {
        if aliveL[i] == 1 && targeted2[i] == 1 {
          aliveL[i] = 0
          longAlive = longAlive - 1
        }
        i = i + 1
      }
    }

    // Output
    let tmax = len(longRounds)
    let tmin = len(shortRounds)
    print("case " + string(tc) + " Y")
    print(string(tmax))
    i = 0
    while i < tmax {
      print(longRounds[i])
      i = i + 1
    }
    print(string(tmin))
    i = 0
    while i < tmin {
      print(shortRounds[i])
      i = i + 1
    }

    tc = tc + 1
  }
}

main()
