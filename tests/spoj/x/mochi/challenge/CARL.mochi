// Solution for SPOJ CARL - Carl's Expressions
// https://www.spoj.com/problems/CARL/
// An expression is either an integer or (p e1 e2).
// Expected value: E(p e1 e2) = E(e1) + (2p - 1) * E(e2)
// Read expressions until "()" terminates input.

fun fmtDecimal(x: float, places: int): string {
  var neg = 0
  var xv = x
  if xv < 0.0 { neg = 1; xv = 0.0 - xv }
  var mult = 1.0
  var i = 0
  while i < places { mult = mult * 10.0; i = i + 1 }
  let scaled = int(xv * mult + 0.5)
  let imult = int(mult)
  let intPart = int(scaled / imult)
  let fracPart = scaled % imult
  var fracStr = str(fracPart)
  while len(fracStr) < places { fracStr = "0" + fracStr }
  var res = str(intPart) + "." + fracStr
  if neg == 1 && (intPart > 0 || fracPart > 0) { res = "-" + res }
  return res
}

// Tokenize: split expression string into tokens "(", ")", or word
fun tokenize(s: string): list<string> {
  var toks: list<string> = []
  var i = 0
  while i < len(s) {
    let c = s[i:i+1]
    if c == "(" || c == ")" {
      toks = append(toks, c)
      i = i + 1
    } else {
      if c == " " {
        i = i + 1
      } else {
        var tok = ""
        while i < len(s) && s[i:i+1] != " " && s[i:i+1] != "(" && s[i:i+1] != ")" {
          tok = tok + s[i:i+1]
          i = i + 1
        }
        if len(tok) > 0 { toks = append(toks, tok) }
      }
    }
  }
  return toks
}

// Evaluate a tokenized CARL expression.
// We maintain a stack of frames. Each frame has:
//   state: 0 = waiting for p, 1 = have p, waiting for e1, 2 = have p+e1, waiting for e2
//   p, e1 values.
// A separate float stack holds ready values.
//
// When we get a "ready" value (literal or computed):
//   - If no open frame, it's the final answer on floatStack.
//   - If current frame is in state 1: store as e1, advance to state 2.
//   - If current frame is in state 2: push to floatStack (it's e2, consumed at ')').
//
// At '(' : push new frame in state 0.
// At word: if current frame state==0, parse as p and advance to state 1.
//          Otherwise parse as integer and deliver as value.
// At ')' : pop frame, compute result = e1 + (2p-1)*e2 where e2 = floatStack.top, deliver result.
fun evalToks(toks: list<string>): float {
  // Frame stacks (parallel arrays)
  var fState: list<int> = []
  var fP: list<float> = []
  var fE1: list<float> = []
  // Value stack for e2 values and final result
  var vStack: list<float> = []

  // Helper: deliver a ready value into the current frame context
  // We can't have nested functions, so inline the logic per case

  var ti = 0
  while ti < len(toks) {
    let tok = toks[ti]
    if tok == "(" {
      fState = append(fState, 0)
      fP = append(fP, 0.0)
      fE1 = append(fE1, 0.0)
    } else {
      if tok == ")" {
        // e2 is top of vStack
        let depth = len(fState)
        let p = fP[depth - 1]
        let e1 = fE1[depth - 1]
        let e2 = vStack[len(vStack) - 1]
        vStack = vStack[0:len(vStack) - 1]
        fState = fState[0:depth - 1]
        fP = fP[0:depth - 1]
        fE1 = fE1[0:depth - 1]
        let result = e1 + (2.0 * p - 1.0) * e2
        // Deliver result to outer frame or vStack
        let outerDepth = len(fState)
        if outerDepth == 0 {
          vStack = append(vStack, result)
        } else {
          let st = fState[outerDepth - 1]
          if st == 1 {
            fE1[outerDepth - 1] = result
            fState[outerDepth - 1] = 2
          } else {
            vStack = append(vStack, result)
          }
        }
      } else {
        // Word token
        let depth = len(fState)
        if depth > 0 && fState[depth - 1] == 0 {
          // This is p for the current frame
          fP[depth - 1] = float(tok)
          fState[depth - 1] = 1
        } else {
          // This is an integer value to deliver
          let v = float(int(tok))
          if depth == 0 {
            vStack = append(vStack, v)
          } else {
            let st = fState[depth - 1]
            if st == 1 {
              fE1[depth - 1] = v
              fState[depth - 1] = 2
            } else {
              vStack = append(vStack, v)
            }
          }
        }
      }
    }
    ti = ti + 1
  }
  return vStack[0]
}

fun main() {
  var line = input()
  while line != "()" {
    if line == "" {
      line = input()
    } else {
      let toks = tokenize(line)
      let result = evalToks(toks)
      print(fmtDecimal(result, 2))
      line = input()
    }
  }
}

main()
