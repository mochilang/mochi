// Solution for SPOJ CARL - Carl's Expressions
// https://www.spoj.com/problems/CARL/
// An expression is either an integer or (p e1 e2).
// Expected value: E(p e1 e2) = E(e1) + (2p - 1) * E(e2)
// Read expressions until "()" terminates input.

fun fmtDecimal(x: float, places: int): string {
  var neg = 0
  var xv = x
  if xv < 0.0 { neg = 1; xv = 0.0 - xv }
  var mult = 1.0
  var i = 0
  while i < places { mult = mult * 10.0; i = i + 1 }
  let scaled = int(xv * mult + 0.5)
  let imult = int(mult)
  let intPart = int(scaled / imult)
  let fracPart = scaled % imult
  var fracStr = str(fracPart)
  while len(fracStr) < places { fracStr = "0" + fracStr }
  var res = str(intPart) + "." + fracStr
  if neg == 1 && (intPart > 0 || fracPart > 0) { res = "-" + res }
  return res
}

// Parse a float from a string like ".5", "0.75", "3"
fun parseFloat(s: string): float {
  var dotPos = 0 - 1
  var i = 0
  while i < len(s) {
    if s[i:i+1] == "." { dotPos = i }
    i = i + 1
  }
  if dotPos == 0 - 1 { return (int(s) as float) }
  var intPart: float = 0.0
  if dotPos > 0 { intPart = (int(s[0:dotPos]) as float) }
  let fracStr = s[dotPos+1:len(s)]
  var fracVal: float = 0.0
  if len(fracStr) > 0 {
    let fracInt = int(fracStr) as float
    var divisor: float = 1.0
    var j = 0
    while j < len(fracStr) { divisor = divisor * 10.0; j = j + 1 }
    fracVal = fracInt / divisor
  }
  return intPart + fracVal
}

// Tokenize: split expression string into tokens "(", ")", or word
fun tokenize(s: string): list<string> {
  var toks: list<string> = []
  var i = 0
  while i < len(s) {
    let c = s[i:i+1]
    if c == "(" || c == ")" {
      toks = append(toks, c)
      i = i + 1
    } else {
      if c == " " {
        i = i + 1
      } else {
        var tok = ""
        while i < len(s) && s[i:i+1] != " " && s[i:i+1] != "(" && s[i:i+1] != ")" {
          tok = tok + s[i:i+1]
          i = i + 1
        }
        if len(tok) > 0 { toks = append(toks, tok) }
      }
    }
  }
  return toks
}

// Evaluate a tokenized CARL expression using an explicit stack.
// Frame stacks: fState (0=need p, 1=have p need e1, 2=have p+e1 need e2),
//               fP (probability), fE1 (expected value of e1).
// Value stack vStack holds ready float values.
//
// When a value is "ready":
//   - If no open frame: push to vStack (final result).
//   - If frame state==1: store as e1, advance to state 2.
//   - If frame state==2: push to vStack (will be e2 at closing ')').
// At '(': push new frame state=0.
// At word: if current frame state==0 → parse as p, advance to 1.
//          else parse as int → deliver as value.
// At ')': e2=vStack.top; pop frame; compute result = e1 + (p+p-1) * e2; deliver result.
fun evalToks(toks: list<string>): float {
  var fState: list<int> = []
  var fP: list<float> = []
  var fE1: list<float> = []
  var vStack: list<float> = []

  var ti = 0
  while ti < len(toks) {
    let tok = toks[ti]
    if tok == "(" {
      fState = append(fState, 0)
      fP = append(fP, 0.0)
      fE1 = append(fE1, 0.0)
    } else {
      if tok == ")" {
        let depth = len(fState)
        let p = fP[depth - 1]
        let e1 = fE1[depth - 1]
        let e2 = vStack[len(vStack) - 1]
        vStack = vStack[0:len(vStack) - 1]
        fState = fState[0:depth - 1]
        fP = fP[0:depth - 1]
        fE1 = fE1[0:depth - 1]
        // coeff = 2p - 1 = p + p - 1.0
        let coeff = p + p - 1.0
        let result = e1 + coeff * e2
        // Deliver result to outer frame or final stack
        let outerDepth = len(fState)
        if outerDepth == 0 {
          vStack = append(vStack, result)
        } else {
          let st = fState[outerDepth - 1]
          if st == 1 {
            fE1[outerDepth - 1] = result
            fState[outerDepth - 1] = 2
          } else {
            vStack = append(vStack, result)
          }
        }
      } else {
        let depth = len(fState)
        if depth > 0 && fState[depth - 1] == 0 {
          // This is p for the current frame
          fP[depth - 1] = parseFloat(tok)
          fState[depth - 1] = 1
        } else {
          // Integer value to deliver
          let v = (int(tok) as float)
          if depth == 0 {
            vStack = append(vStack, v)
          } else {
            let st = fState[depth - 1]
            if st == 1 {
              fE1[depth - 1] = v
              fState[depth - 1] = 2
            } else {
              vStack = append(vStack, v)
            }
          }
        }
      }
    }
    ti = ti + 1
  }
  return vStack[0]
}

fun main() {
  var line = input()
  while line != "()" {
    if line == "" {
      line = input()
    } else {
      let toks = tokenize(line)
      let result = evalToks(toks)
      print(fmtDecimal(result, 2))
      line = input()
    }
  }
}

main()
