// Solution for SPOJ BALLS - Distributing the balls
// https://www.spoj.com/problems/BALLS/
// Surjections of A distinguishable balls into B cells: inclusion-exclusion.
// Answer = sum_{k=0}^{B} (-1)^k * C(B,k) * (B-k)^A  mod 247383691

let M = 247383691

fun powmod(base: int, exp: int, m: int): int {
  var result = 1
  var b = base % m
  var e = exp
  while e > 0 {
    if e % 2 == 1 { result = result * b % m }
    b = b * b % m
    e = int(e / 2)
  }
  return result
}

// Build Pascal's triangle mod M up to row 100
fun buildC(): list<list<int>> {
  var C: list<list<int>> = []
  var i = 0
  while i <= 100 {
    var row: list<int> = []
    var j = 0
    while j <= 100 {
      row = append(row, 0)
      j = j + 1
    }
    C = append(C, row)
    i = i + 1
  }
  C[0][0] = 1
  var r = 1
  while r <= 100 {
    C[r][0] = 1
    var c = 1
    while c <= r {
      C[r][c] = (C[r-1][c-1] + C[r-1][c]) % M
      c = c + 1
    }
    r = r + 1
  }
  return C
}

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else {
      cur = cur + line[i:i+1]
    }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun main() {
  let C = buildC()
  var line = input()
  while line != "" {
    let p = split(line)
    if len(p) >= 2 {
      let A = int(p[0])
      let B = int(p[1])
      var ans = 0
      var k = 0
      while k <= B {
        let term = C[B][k] * powmod(B - k, A, M) % M
        if k % 2 == 0 {
          ans = (ans + term) % M
        } else {
          ans = (ans - term + M) % M
        }
        k = k + 1
      }
      print(ans)
    }
    line = input()
  }
}

main()
