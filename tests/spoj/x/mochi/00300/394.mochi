// Solution for SPOJ ACODE - Alphacode
// https://www.spoj.com/problems/ACODE/
// Count ways to decode digit string where A=1..Z=26.

fun main() {
  var line = input()
  while line != "" {
    if line == "0" { break }
    let n = len(line)
    var dp: list<int> = []
    var i = 0
    while i <= n { dp = append(dp, 0); i = i + 1 }
    dp[0] = 1
    if line[0:1] != "0" { dp[1] = 1 }

    i = 2
    while i <= n {
      let c1 = line[i-1:i]
      if c1 != "0" { dp[i] = dp[i] + dp[i-1] }
      let c2 = line[i-2:i]
      let v = int(c2)
      if v >= 10 && v <= 26 { dp[i] = dp[i] + dp[i-2] }
      i = i + 1
    }
    print(dp[n])
    line = input()
  }
}

main()
