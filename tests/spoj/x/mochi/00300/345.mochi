// Solution for SPOJ Mixtures (MIXTURES)
// https://www.spoj.com/problems/MIXTURES/
// Interval DP: minimize total smoke when merging N mixtures into one.
// dp_smoke[i*N+j] = min smoke to merge mixtures i..j
// dp_qty[i*N+j]   = total quantity of i..j (used in smoke calculation)

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == " " {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else { cur = cur + line[i:i+1] }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun main() {
  var line = input()
  while line != "" {
    let n = int(line)
    if n == 0 { return }

    var qty: list<int> = []
    var i = 0
    while i < n {
      let parts = split(input())
      // color is parts[0], quantity is parts[1]
      qty = append(qty, int(parts[1]))
      i = i + 1
    }

    // Initialize DP arrays of size n*n
    var dpSmoke: list<int> = []
    var dpQty: list<int> = []
    let INF = 1000000000
    i = 0
    while i < n * n {
      dpSmoke = append(dpSmoke, INF)
      dpQty = append(dpQty, 0)
      i = i + 1
    }

    // Base case: single mixtures
    i = 0
    while i < n {
      dpSmoke[i*n+i] = 0
      dpQty[i*n+i] = qty[i]
      i = i + 1
    }

    // Fill by increasing interval length
    var length = 2
    while length <= n {
      i = 0
      while i + length - 1 < n {
        let j = i + length - 1
        // Precompute total qty for i..j
        var totalQty = 0
        var q = i
        while q <= j {
          totalQty = totalQty + qty[q]
          q = q + 1
        }
        dpQty[i*n+j] = totalQty

        var best = INF
        var k = i
        while k < j {
          let smoke = dpSmoke[i*n+k] + dpSmoke[(k+1)*n+j] + dpQty[i*n+k] * dpQty[(k+1)*n+j]
          if smoke < best { best = smoke }
          k = k + 1
        }
        dpSmoke[i*n+j] = best
        i = i + 1
      }
      length = length + 1
    }

    print(dpSmoke[0*n+(n-1)])
    line = input()
  }
}

main()
