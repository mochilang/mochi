// Solution for SPOJ EDIST - Edit Distance
// https://www.spoj.com/problems/EDIST/
// Standard Levenshtein distance DP with O(n) space rolling array.

fun main() {
  var tLine = input()
  while tLine == "" { tLine = input() }
  let t = int(tLine)
  var ti = 0
  while ti < t {
    var s = input()
    while s == "" { s = input() }
    var tt = input()
    while tt == "" { tt = input() }

    let n = len(s)
    let m = len(tt)

    // dp[j] = edit distance between s[0:i] and t[0:j]
    var dp: list<int> = []
    var j = 0
    while j <= m { dp = append(dp, j); j = j + 1 }

    var i = 1
    while i <= n {
      var prev = i - 1
      dp[0] = i
      j = 1
      while j <= m {
        let tmp = dp[j]
        if s[i-1:i] == tt[j-1:j] {
          dp[j] = prev
        } else {
          var best = prev + 1
          if dp[j] + 1 < best { best = dp[j] + 1 }
          if dp[j-1] + 1 < best { best = dp[j-1] + 1 }
          dp[j] = best
        }
        prev = tmp
        j = j + 1
      }
      i = i + 1
    }

    print(dp[m])
    ti = ti + 1
  }
}

main()
