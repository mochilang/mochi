// Solution for SPOJ HANGOVER - Hangover
// https://www.spoj.com/problems/HANGOVER/
// Min cards to overhang >= d: overhang(n) = sum(1/(2k), k=1..n).

fun split(line: string): list<string> {
  var parts: list<string> = []
  var cur = ""
  var i = 0
  while i < len(line) {
    if line[i:i+1] == "." {
      if len(cur) > 0 { parts = append(parts, cur); cur = "" }
    } else { cur = cur + line[i:i+1] }
    i = i + 1
  }
  if len(cur) > 0 { parts = append(parts, cur) }
  return parts
}

fun main() {
  var line = input()
  while line != "" {
    // Parse d as float
    let ps = split(line)
    var d = int(ps[0]) as float
    if len(ps) > 1 {
      let frac = ps[1]
      var f = int(frac) as float
      var div = 1.0
      var i = 0
      while i < len(frac) { div = div * 10.0; i = i + 1 }
      d = d + f / div
    }
    if d == 0.0 { print(0); line = input(); continue }

    var sum = 0.0
    var cards = 0
    var k = 1
    while sum < d {
      sum = sum + 1.0 / (2.0 * (k as float))
      cards = cards + 1
      k = k + 1
    }
    print(cards)
    line = input()
  }
}

main()
