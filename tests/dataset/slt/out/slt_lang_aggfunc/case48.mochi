/*
# line: 361
# EVIDENCE-OF: R-10396-30188 Aggregate min() returns NULL if and only if
# there are no non-NULL values in the group.
*/

type t1Row {
  x: int
  y: string
}

let t1 = [
  t1Row {
    x: 1,
    y: "tru" + "e",
  },
  t1Row {
    x: 0,
    y: "fal" + "se",
  },
  t1Row {
    x: none,
    y: "NULL",
  },
  t1Row {
    x: 2,
    y: "tru" + "e",
  },
  t1Row {
    x: 2,
    y: "tru" + "e",
  },
]

/* SELECT min(x) FROM t1 WHERE y='none' */
let result = min(from row in t1
  where (row.y != none && "null" != none && row.y == "null") && row.x != none
  select row.x)
print(result)

test "case48" {
  expect result == none
}
