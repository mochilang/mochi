/*
# line: 206
*/

type t1Row {
  x: int
  y: string
}

let t1 = [
  t1Row {
    x: 1,
    y: "tru" + "e",
  },
  t1Row {
    x: 0,
    y: "fal" + "se",
  },
  t1Row {
    x: none,
    y: "NULL",
  },
  t1Row {
    x: 2,
    y: "tru" + "e",
  },
  t1Row {
    x: 2,
    y: "tru" + "e",
  },
]

/* SELECT count(DISTINCT x) FROM t1 WHERE y='none' */
let result = count(distinct(from row in t1
  where (row.y != none && "null" != none && row.y == "null") && row.x != none
  select row))
print(result)

test "case29" {
  expect result == 0
}
