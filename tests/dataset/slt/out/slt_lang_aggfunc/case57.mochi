/*
# line: 414
*/

type t1Row {
  x: int
  y: string
}

let t1 = [
  t1Row {
    x: 1,
    y: "tru" + "e",
  },
  t1Row {
    x: 0,
    y: "fal" + "se",
  },
  t1Row {
    x: none,
    y: "NULL",
  },
  t1Row {
    x: 2,
    y: "tru" + "e",
  },
  t1Row {
    x: 2,
    y: "tru" + "e",
  },
]

/* SELECT total(DISTINCT x) FROM t1 WHERE y='none' */
var result = sum(distinct(from row in t1
  where (row.y != none && "null" != none && row.y == "null") && row.x != none
  select row.x))
result = if result == none then 0.0 else (result as float)
print(result)

test "case57" {
  expect result == 0
}
