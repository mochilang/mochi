type: [{string: int}]
plan:
(select
  (map
    (entry
      (selector orderId)
      (selector id (selector o))
    )
    (entry
      (selector customerName)
      (selector name (selector c))
    )
  )
  (join
    (scan o (selector orders))
    (scan c (selector customers))
    (on
      (binary ==
        (selector customerId (selector o))
        (selector id (selector c))
      )
    )
  )
)
