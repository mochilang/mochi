package main

import (
	"encoding/json"
	"os"
	"time"
)

func sumLoop(n int) int {
	total := 0
	for i := 1; i < n; i++ {
		total += i
	}
	return total
}

func main() {
	const n = {{ .N }}
	const repeat = 1000
	var last int

	start := time.Now()
	for i := 0; i < repeat; i++ {
		last = sumLoop(n)
	}
	durUs := float64(time.Since(start).Microseconds())

	_ = json.NewEncoder(os.Stdout).Encode(map[string]any{
		"duration_us": durUs,
		"output":      last,
	})
}
